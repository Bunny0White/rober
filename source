-- ── 4. FLY ──────────────────────────────────────────────────────────────
local function StartFly()
    local r=Root(); local h=Hum(); if not r or not h then return end
    h.PlatformStand=true
    FlyBV=Instance.new("BodyVelocity"); FlyBV.Velocity=Vector3.zero
    FlyBV.MaxForce=Vector3.new(1e5,1e5,1e5); FlyBV.Parent=r
    FlyBG=Instance.new("BodyGyro"); FlyBG.MaxTorque=Vector3.new(1e5,1e5,1e5)
    FlyBG.CFrame=r.CFrame; FlyBG.P=1e4; FlyBG.Parent=r
    local cam=workspace.CurrentCamera
    FlyConn=RunService.Heartbeat:Connect(function()
        if not State.Fly or not FlyBV or not FlyBG then return end
        local dir=Vector3.zero
        local UIS=UserInputService
        if UIS:IsKeyDown(Enum.KeyCode.W) or UIS:IsKeyDown(Enum.KeyCode.Z) then dir=dir+cam.CFrame.LookVector  end
        if UIS:IsKeyDown(Enum.KeyCode.S)                                   then dir=dir-cam.CFrame.LookVector  end
        if UIS:IsKeyDown(Enum.KeyCode.A) or UIS:IsKeyDown(Enum.KeyCode.Q) then dir=dir-cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D)                                   then dir=dir+cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.yAxis end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.yAxis end
        FlyBV.Velocity=(dir.Magnitude>0 and dir.Unit or Vector3.zero)*CFG.FlySpeed
        FlyBG.CFrame=cam.CFrame
    end)
end
local function StopFly()
    if FlyConn then FlyConn:Disconnect() FlyConn=nil end
    if FlyBV   then FlyBV:Destroy()   FlyBV=nil   end
    if FlyBG   then FlyBG:Destroy()   FlyBG=nil   end
    local h=Hum(); if h then h.PlatformStand=false end
end
local function ToggleFly(on)
    if on then StartFly(); Notify("Fly Mode","ZQSD · Espace · Shift","on")
    else StopFly(); Notify("Fly Mode","Désactivé","off") end
end

-- ── 5. GOD MODE ─────────────────────────────────────────────────────────
local function ToggleGodMode(on)
    if GodConn then GodConn:Disconnect() GodConn=nil end
    if on then
        GodConn=RunService.Heartbeat:Connect(function()
            local h=Hum(); if h and h.Health<h.MaxHealth then h.Health=h.MaxHealth end
        end)
        Notify("God Mode","HP maintenue au maximum (client)","on")
    else Notify("God Mode","Désactivé","off") end
end

-- ── 6. INFINITE JUMP ────────────────────────────────────────────────────
local function ToggleInfiniteJump(on)
    if InfJumpConn then InfJumpConn:Disconnect() InfJumpConn=nil end
    if on then
        InfJumpConn=Track(UserInputService.JumpRequest:Connect(function()
            local h=Hum(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
        end))
        Notify("Infinite Jump","Sauts illimités activés","on")
    else Notify("Infinite Jump","Désactivé","off") end
end

-- ── 7. NOCLIP ───────────────────────────────────────────────────────────
local function ToggleNoClip(on)
    if NoClipConn then NoClipConn:Disconnect() NoClipConn=nil end
    if on then
        NoClipConn=RunService.Stepped:Connect(function()
            local c=Char(); if not c then return end
            for _,part in ipairs(c:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide=false end
            end
        end)
        Notify("NoClip","Collision désactivée","on")
    else
        local c=Char()
        if c then
            for _,part in ipairs(c:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide=true end
            end
        end
        Notify("NoClip","Collision restaurée","off")
    end
end

-- ── 8. NAMETAGS ─────────────────────────────────────────────────────────
local function MakeTag(player)
    if player==LocalPlayer then return end
    local c=player.Character; if not c then return end
    local head=c:FindFirstChild("Head"); if not head then return end
    if head:FindFirstChild("__APtag") then return end
    local bb=Instance.new("BillboardGui")
    bb.Name="__APtag"; bb.Size=UDim2.new(0,160,0,34)
    bb.StudsOffset=Vector3.new(0,3.5,0); bb.AlwaysOnTop=true; bb.Parent=head
    local bg=Instance.new("Frame")
    bg.Size=UDim2.new(1,0,1,0); bg.BackgroundColor3=Color3.fromRGB(8,9,18)
    bg.BackgroundTransparency=0.3; bg.BorderSizePixel=0; bg.Parent=bb
    Instance.new("UICorner",bg).CornerRadius=UDim.new(0,6)
    local bar=Instance.new("Frame")
    bar.Size=UDim2.new(0,3,0.8,0); bar.Position=UDim2.new(0,3,0.1,0)
    bar.BackgroundColor3=Color3.fromRGB(99,140,255); bar.BorderSizePixel=0; bar.Parent=bg
    Instance.new("UICorner",bar).CornerRadius=UDim.new(1,0)
    local tx=Instance.new("TextLabel")
    tx.Size=UDim2.new(1,-12,0.55,0); tx.Position=UDim2.new(0,10,0.05,0)
    tx.BackgroundTransparency=1; tx.Font=Enum.Font.GothamBold
    tx.Text=player.Name; tx.TextColor3=Color3.fromRGB(200,210,255)
    tx.TextStrokeTransparency=0.5; tx.TextSize=12; tx.TextXAlignment=Enum.TextXAlignment.Left
    tx.Parent=bg
    local sub=Instance.new("TextLabel")
    sub.Size=UDim2.new(1,-12,0.4,0); sub.Position=UDim2.new(0,10,0.55,0)
    sub.BackgroundTransparency=1; sub.Font=Enum.Font.Gotham
    sub.Text="HP: --"; sub.TextColor3=Color3.fromRGB(80,200,140)
    sub.TextSize=10; sub.TextXAlignment=Enum.TextXAlignment.Left; sub.Parent=bg

    local hpConn
    hpConn=RunService.Heartbeat:Connect(function()
        if not (bb and bb.Parent) then if hpConn then hpConn:Disconnect() end return end
        local ph=player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if ph then
            local pct=math.floor((ph.Health/ph.MaxHealth)*100)
            sub.Text="HP: "..pct.."%"
            local g=pct/100
            sub.TextColor3=Color3.fromRGB(math.floor(255*(1-g)),math.floor(200*g+55),math.floor(80*g))
        end
    end)
end

local function RemoveTag(player)
    local c=player.Character; if not c then return end
    local head=c:FindFirstChild("Head"); if not head then return end
    local tag=head:FindFirstChild("__APtag"); if tag then tag:Destroy() end
end
local function ToggleNametags(on)
    if on then
        for _,p in ipairs(Players:GetPlayers()) do MakeTag(p) end
        Track(Players.PlayerAdded:Connect(function(p)
            Track(p.CharacterAdded:Connect(function()
                task.wait(0.5); if State.Nametags then MakeTag(p) end
            end))
        end))
        Notify("Nametags","Noms + HP affichés","on")
    else
        for _,p in ipairs(Players:GetPlayers()) do RemoveTag(p) end
        Notify("Nametags","Désactivé","off")
    end
end

