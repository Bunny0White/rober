local function GetPlayerLevel()
	local pg = LocalPlayer.PlayerGui
	local mainGui = pg:FindFirstChild("MainGui")
	if not mainGui then return 1 end
	local baseFrame = mainGui:FindFirstChild("BaseFrame")
	if not baseFrame then return 1 end
	local frame = baseFrame:FindFirstChild("Frame")
	if not frame then return 1 end
	local lvlLabel = frame:FindFirstChild("Lvl")
	if lvlLabel and lvlLabel:IsA("TextLabel") then
		local n = tonumber(lvlLabel.Text)
		if n then return n end
	end
	for _, child in ipairs(frame:GetDescendants()) do
		if child:IsA("TextLabel") then
			local n = tonumber(child.Text)
			if n and n > 0 then return n end
		end
	end
	return 1
end

local function GetAllMobs()
	local list = {}
	local monster = workspace:FindFirstChild("Monster")
	if not monster then return list end
	local mon = monster:FindFirstChild("Mon")
	if not mon then return list end
	for _, mob in ipairs(mon:GetChildren()) do
		local hum = mob:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then
			table.insert(list, mob)
		end
	end
	return list
end

local function GetAllBosses()
	local list = {}
	local monster = workspace:FindFirstChild("Monster")
	if not monster then return list end
	local bossFolder = monster:FindFirstChild("Boss")
	if not bossFolder then return list end
	for _, boss in ipairs(bossFolder:GetChildren()) do
		local hum = boss:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then
			table.insert(list, boss)
		end
	end
	return list
end

local function GetMobLevel(name)
	local lv = name:match("%[Lv%.%s*(%d+)%]")
	if lv then return tonumber(lv) end
	local tier = name:match("[Tt]ier%s*(%d+)")
	if tier then return tonumber(tier) * 10 end
	return 0
end

local function FindBestTarget()
	local playerLvl = GetPlayerLevel()
	local bosses = GetAllBosses()
	local mobs   = GetAllMobs()

	local bestBoss = nil
	local bestBossLvl = 0
	for _, boss in ipairs(bosses) do
		local lvl = GetMobLevel(boss.Name)
		if lvl <= playerLvl and lvl >= bestBossLvl then
			bestBoss = boss
			bestBossLvl = lvl
		end
	end
	if bestBoss then return bestBoss, true end

	local bestMob = nil
	local bestMobLvl = 0
	for _, mob in ipairs(mobs) do
		local lvl = GetMobLevel(mob.Name)
		if lvl <= playerLvl and lvl >= bestMobLvl then
			bestMob = mob
			bestMobLvl = lvl
		end
	end
	return bestMob, false
end

local function FindTargetByName(targetName, isBoss)
	local folder
	local monster = workspace:FindFirstChild("Monster")
	if not monster then return nil end
	if isBoss then
		folder = monster:FindFirstChild("Boss")
	else
		folder = monster:FindFirstChild("Mon")
	end
	if not folder then return nil end

	local best = nil
	local lname = targetName:lower()
	for _, obj in ipairs(folder:GetChildren()) do
		local hum = obj:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then
			if obj.Name:lower():find(lname, 1, true) then
				best = obj
				break
			end
		end
	end
	return best
end

local function AttackTarget(target)
	local r = Root()
	local targetRoot = target:FindFirstChild("HumanoidRootPart")
	if not r or not targetRoot then return end
	r.CFrame = targetRoot.CFrame * CFrame.new(0, 0, -2.5)
	local char = Char()
	if char then
		for _, tool in ipairs(char:GetChildren()) do
			if tool:IsA("Tool") then
				local remote = tool:FindFirstChildOfClass("RemoteEvent") or tool:FindFirstChild("ActivateEvent")
				if remote then
					pcall(function() remote:FireServer() end)
				end
				pcall(function()
					local handle = tool:FindFirstChild("Handle")
					if handle then tool:Activate() end
				end)
			end
		end
	end
end

local function GetMobNames()
	local names = {}
	local seen = {}
	local monster = workspace:FindFirstChild("Monster")
	if not monster then return names end
	local mon = monster:FindFirstChild("Mon")
	if mon then
		for _, obj in ipairs(mon:GetChildren()) do
			if not seen[obj.Name] then
				seen[obj.Name] = true
				table.insert(names, {name = obj.Name, isBoss = false})
			end
		end
	end
	return names
end

local function GetBossNames()
	local names = {}
	local seen = {}
	local monster = workspace:FindFirstChild("Monster")
	if not monster then return names end
	local bossFolder = monster:FindFirstChild("Boss")
	if bossFolder then
		for _, obj in ipairs(bossFolder:GetChildren()) do
			if not seen[obj.Name] then
				seen[obj.Name] = true
				table.insert(names, {name = obj.Name, isBoss = true})
			end
		end
	end
	return names
end

local FarmStatusLabel = nil

local function UpdateFarmStatus(txt)
	FarmStatus = txt
	if FarmStatusLabel and FarmStatusLabel.Parent then
		FarmStatusLabel.Text = txt
	end
end

local function StartAutoFarm()
	if AutoFarmConn then AutoFarmConn:Disconnect(); AutoFarmConn = nil end
	UpdateFarmStatus("⚡ Démarrage...")
	AutoFarmConn = RunService.Heartbeat:Connect(function()
		if not State.AutoFarm then return end
		local target = nil
		local isBoss = false

		if State.AutoFarmByLevel then
			target, isBoss = FindBestTarget()
			if target then
				local label = isBoss and ("Boss: " .. target.Name) or ("Mob: " .. target.Name)
				UpdateFarmStatus((isBoss and "👑 " or "⚔ ") .. label)
			else
				UpdateFarmStatus("❓ Aucune cible trouvée")
			end
		elseif FarmTargetName then
			target = FindTargetByName(FarmTargetName, FarmTargetIsBoss)
			if target then
				UpdateFarmStatus((FarmTargetIsBoss and "👑 " or "⚔ ") .. target.Name)
			else
				UpdateFarmStatus("❓ " .. FarmTargetName .. " introuvable")
			end
		else
			UpdateFarmStatus("⚠ Sélectionnez une cible")
			return
		end

		if target then AttackTarget(target) end
	end)
end

local function StopAutoFarm()
	if AutoFarmConn then AutoFarmConn:Disconnect(); AutoFarmConn = nil end
	UpdateFarmStatus("Inactif")
end

