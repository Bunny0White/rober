local logEntries = {}
local function addLog(msg, color)
	color = color or Color3.fromRGB(200, 200, 220)
	local lbl = Instance.new("TextLabel", logFrame)
	lbl.Size              = UDim2.new(1, 0, 0, 18)
	lbl.BackgroundTransparency = 1
	lbl.Text              = msg
	lbl.TextColor3        = color
	lbl.TextXAlignment    = Enum.TextXAlignment.Left
	lbl.TextScaled        = true
	lbl.Font              = Enum.Font.Code
	lbl.LayoutOrder       = #logEntries + 1
	table.insert(logEntries, lbl)

	if #logEntries > 40 then
		logEntries[1]:Destroy()
		table.remove(logEntries, 1)
	end

	-- scroll to bottom
	logLayout:ApplyLayout()
	logFrame.CanvasSize = UDim2.new(0, 0, 0, logLayout.AbsoluteContentSize.Y + 8)
	logFrame.CanvasPosition = Vector2.new(0, math.huge)
end

