-- ESP ─────────────────────────────────────────────────────────────────
local function ApplyESP(p)
	if p == LocalPlayer then return end
	local c = p.Character; if not c or c:FindFirstChild("__APesp") then return end
	local hl = Instance.new("Highlight")
	hl.Name = "__APesp"; hl.FillColor = CFG.ESPFill; hl.OutlineColor = CFG.ESPOutline
	hl.FillTransparency = 0.5; hl.OutlineTransparency = 0
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = c
end
local function RemoveESP(p)
	local c = p.Character; if not c then return end
	local hl = c:FindFirstChild("__APesp"); if hl then hl:Destroy() end
end
local function ToggleESP(on)
	if on then
		for _, p in ipairs(Players:GetPlayers()) do ApplyESP(p) end
		Track(Players.PlayerAdded:Connect(function(p)
			Track(p.CharacterAdded:Connect(function() task.wait(0.4); if State.ESP then ApplyESP(p) end end))
		end))
		Notify("ESP", "Joueurs mis en évidence", "on")
	else
		for _, p in ipairs(Players:GetPlayers()) do RemoveESP(p) end
		Notify("ESP", "Désactivé", "off")
	end
end

