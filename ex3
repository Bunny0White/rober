local activeModal = nil

function openModal(gui)
    if activeModal and activeModal.Parent then
        activeModal:Destroy()
    end

    local dump = dumpGui(gui)
    print(dump) -- print dans la console Output

    local modal = Instance.new("Frame")
    modal.Size = UDim2.fromOffset(480, 420)
    modal.Position = UDim2.fromOffset(300, 150)
    modal.BackgroundColor3 = Color3.fromRGB(20, 20, 32)
    modal.BorderSizePixel = 0
    modal.ZIndex = 20
    modal.Parent = screen
    Instance.new("UICorner", modal).CornerRadius = UDim.new(0, 10)

    activeModal = modal

    -- Barre titre modal (handle drag)
    local header = Instance.new("TextLabel")
    header.Size = UDim2.new(1, 0, 0, 32)
    header.Text = "  🔎 Inspect : " .. gui.Name .. "  [" .. gui.ClassName .. "]"
    header.TextXAlignment = Enum.TextXAlignment.Left
    header.BackgroundColor3 = Color3.fromRGB(40, 40, 65)
    header.TextColor3 = Color3.new(1, 1, 1)
    header.TextSize = 13
    header.Font = Enum.Font.GothamBold
    header.BorderSizePixel = 0
    header.ZIndex = 21
    header.Parent = modal
    Instance.new("UICorner", header).CornerRadius = UDim.new(0, 10)

    makeDraggable(modal, header)

    -- Bouton Fermer modal
    local close = Instance.new("TextButton")
    close.Size = UDim2.fromOffset(24, 24)
    close.Position = UDim2.new(1, -28, 0, 4)
    close.Text = "✕"
    close.TextSize = 12
    close.Font = Enum.Font.GothamBold
    close.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    close.TextColor3 = Color3.new(1, 1, 1)
    close.BorderSizePixel = 0
    close.ZIndex = 22
    close.Parent = modal
    Instance.new("UICorner", close).CornerRadius = UDim.new(1, 0)

    close.MouseButton1Click:Connect(function()
        modal:Destroy()
        activeModal = nil
    end)

    -- Zone de texte scrollable
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -10, 1, -78)
    scroll.Position = UDim2.new(0, 5, 0, 37)
    scroll.BackgroundColor3 = Color3.fromRGB(32, 32, 48)
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 5
    scroll.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 180)
    scroll.ZIndex = 21
    scroll.Parent = modal
    Instance.new("UICorner", scroll).CornerRadius = UDim.new(0, 6)

    local content = Instance.new("TextLabel")
    content.Size = UDim2.new(1, -10, 0, 0)
    content.Position = UDim2.new(0, 5, 0, 5)
    content.BackgroundTransparency = 1
    content.Text = dump
    content.TextColor3 = Color3.fromRGB(210, 210, 230)
    content.TextSize = 12
    content.Font = Enum.Font.Code
    content.TextXAlignment = Enum.TextXAlignment.Left
    content.TextYAlignment = Enum.TextYAlignment.Top
    content.TextWrapped = true
    content.RichText = false
    content.AutomaticSize = Enum.AutomaticSize.Y
    content.ZIndex = 22
    content.Parent = scroll

    content:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, content.AbsoluteSize.Y + 10)
    end)

    -- Bouton Copier
    local copy = Instance.new("TextButton")
    copy.Size = UDim2.new(1, -10, 0, 30)
    copy.Position = UDim2.new(0, 5, 1, -36)
    copy.Text = "📋  Copier le print"
    copy.TextSize = 13
    copy.Font = Enum.Font.GothamBold
    copy.BackgroundColor3 = Color3.fromRGB(40, 110, 40)
    copy.TextColor3 = Color3.new(1, 1, 1)
    copy.BorderSizePixel = 0
    copy.ZIndex = 22
    copy.Parent = modal
    Instance.new("UICorner", copy).CornerRadius = UDim.new(0, 6)

    copy.MouseButton1Click:Connect(function()
        copyToClipboard(dump)
        copy.Text = "✅  Copié !"
        copy.BackgroundColor3 = Color3.fromRGB(30, 150, 80)
        task.delay(2, function()
            if copy and copy.Parent then
                copy.Text = "📋  Copier le print"
                copy.BackgroundColor3 = Color3.fromRGB(40, 110, 40)
            end
        end)
    end)
end

