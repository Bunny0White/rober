--  TOGGLE PANEL
-- ══════════════════════════════════════════════════════════════════════
local panelOpen = false

local function OpenPanel()
	panelOpen = true; Main.Visible = true
	Main.Size = UDim2.new(0, TOTAL_W, 0, 0)
	Tw(Main, TI(0.38, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{Size = UDim2.new(0, TOTAL_W, 0, PANEL_H)})
	TArrow.Text = "▴"
	Tw(TBtnStr, TI(0.2), {Transparency = 0.1})
end

local function ClosePanel()
	panelOpen = false
	Tw(Main, TI(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In),
		{Size = UDim2.new(0, TOTAL_W, 0, 0)})
	task.delay(0.32, function() if not panelOpen then Main.Visible = false end end)
	TArrow.Text = "▾"
	Tw(TBtnStr, TI(0.2), {Transparency = 0.55})
end

TBtnClick.MouseButton1Click:Connect(function()
	if not tbDrag then
		if panelOpen then ClosePanel() else OpenPanel() end
	end
end)

Track(UserInputService.InputBegan:Connect(function(inp, proc)
	if not proc and inp.KeyCode == Enum.KeyCode.G then
		if panelOpen then ClosePanel() else OpenPanel() end
	end
end))

