local nIdx = 0
local function Notify(title, body, kind)
	if not State.NotifEnabled then return end
	nIdx = nIdx + 1
	local accent = kind == "on" and C.green or kind == "off" and C.red
		or kind == "warn" and C.yellow or C.blue

	local card = Instance.new("Frame")
	card.Size = UDim2.new(1, 0, 0, 0); card.ClipsDescendants = true
	card.BackgroundColor3 = C.base; card.BackgroundTransparency = 1
	card.BorderSizePixel = 0; card.LayoutOrder = -nIdx; card.Parent = NStack
	Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
	local str = Instance.new("UIStroke", card)
	str.Color = accent; str.Thickness = 1; str.Transparency = 0.5

	local pill = Instance.new("Frame")
	pill.Size = UDim2.new(0, 3, 1, -12); pill.Position = UDim2.new(0, 0, 0, 6)
	pill.BackgroundColor3 = accent; pill.BorderSizePixel = 0; pill.Parent = card
	Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

	local tit = Instance.new("TextLabel")
	tit.Size = UDim2.new(1, -18, 0, 16); tit.Position = UDim2.new(0, 12, 0, 7)
	tit.BackgroundTransparency = 1; tit.Font = Enum.Font.GothamBold
	tit.Text = title; tit.TextColor3 = C.t1; tit.TextSize = 12
	tit.TextXAlignment = Enum.TextXAlignment.Left; tit.Parent = card

	local bod = Instance.new("TextLabel")
	bod.Size = UDim2.new(1, -18, 0, 13); bod.Position = UDim2.new(0, 12, 0, 23)
	bod.BackgroundTransparency = 1; bod.Font = Enum.Font.Gotham
	bod.Text = body; bod.TextColor3 = C.t2; bod.TextSize = 10
	bod.TextXAlignment = Enum.TextXAlignment.Left; bod.Parent = card

	local prog = Instance.new("Frame")
	prog.Size = UDim2.new(1, 0, 0, 2); prog.Position = UDim2.new(0, 0, 1, -2)
	prog.BackgroundColor3 = accent; prog.BorderSizePixel = 0; prog.ZIndex = 2; prog.Parent = card
	Instance.new("UICorner", prog).CornerRadius = UDim.new(1, 0)

	Tw(card, TI(0.28, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, 46), BackgroundTransparency = 0})
	task.spawn(function()
		task.wait(0.3)
		Tw(prog, TI(2.8, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2)})
	end)
	task.delay(3.2, function()
		for _, ch in ipairs(card:GetDescendants()) do
			if ch:IsA("TextLabel") then Tw(ch, TI(0.22), {TextTransparency = 1}) end
			if ch:IsA("Frame")     then Tw(ch, TI(0.22), {BackgroundTransparency = 1}) end
			if ch:IsA("UIStroke")  then Tw(ch, TI(0.22), {Transparency = 1}) end
		end
		Tw(card, TI(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
			{BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)})
		task.delay(0.35, function() pcall(function() card:Destroy() end) end)
	end)
end

