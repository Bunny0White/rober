--  TOGGLE ROW
-- ════════════════════════════════════════════════════════════════
local function MakeToggle(icon, label, desc, key, order)
    local Row = Instance.new("Frame")
    Row.Size=UDim2.new(1,-12,0,54); Row.BackgroundColor3=C.bg2
    Row.BorderSizePixel=0; Row.LayoutOrder=order; Row.Parent=Scroll
    Instance.new("UICorner",Row).CornerRadius=UDim.new(0,10)

    -- Bord gauche (accent actif)
    local AccBar = Instance.new("Frame")
    AccBar.Size=UDim2.new(0,3,0,32); AccBar.Position=UDim2.new(0,0,0.5,-16)
    AccBar.BackgroundColor3=C.accent; AccBar.BorderSizePixel=0
    AccBar.BackgroundTransparency=1; AccBar.ZIndex=13; AccBar.Parent=Row
    Instance.new("UICorner",AccBar).CornerRadius=UDim.new(1,0)

    -- Icône
    local IconF = Instance.new("Frame")
    IconF.Size=UDim2.new(0,32,0,32); IconF.Position=UDim2.new(0,11,0.5,-16)
    IconF.BackgroundColor3=C.bg0; IconF.BorderSizePixel=0; IconF.ZIndex=13
    IconF.Parent=Row
    Instance.new("UICorner",IconF).CornerRadius=UDim.new(0,9)
    local IconTxt = Instance.new("TextLabel")
    IconTxt.Size=UDim2.new(1,0,1,0); IconTxt.BackgroundTransparency=1
    IconTxt.Font=Enum.Font.GothamBold; IconTxt.Text=icon
    IconTxt.TextSize=16; IconTxt.TextColor3=C.txt2; IconTxt.ZIndex=14
    IconTxt.Parent=IconF

    -- Textes
    local Lbl = Instance.new("TextLabel")
    Lbl.Size=UDim2.new(1,-110,0,18); Lbl.Position=UDim2.new(0,50,0,9)
    Lbl.BackgroundTransparency=1; Lbl.Font=Enum.Font.GothamBold
    Lbl.Text=label; Lbl.TextColor3=C.txt1; Lbl.TextSize=13
    Lbl.TextXAlignment=Enum.TextXAlignment.Left; Lbl.ZIndex=13; Lbl.Parent=Row

    local Desc = Instance.new("TextLabel")
    Desc.Size=UDim2.new(1,-110,0,13); Desc.Position=UDim2.new(0,50,0,27)
    Desc.BackgroundTransparency=1; Desc.Font=Enum.Font.Gotham
    Desc.Text=desc; Desc.TextColor3=C.txt2; Desc.TextSize=10
    Desc.TextXAlignment=Enum.TextXAlignment.Left; Desc.ZIndex=13; Desc.Parent=Row

    -- Rail + Knob
    local Rail = Instance.new("Frame")
    Rail.Size=UDim2.new(0,44,0,22); Rail.Position=UDim2.new(1,-54,0.5,-11)
    Rail.BackgroundColor3=C.railOff; Rail.BorderSizePixel=0; Rail.ZIndex=13
    Rail.Parent=Row
    Instance.new("UICorner",Rail).CornerRadius=UDim.new(1,0)
    local Knob = Instance.new("Frame")
    Knob.Size=UDim2.new(0,16,0,16); Knob.Position=UDim2.new(0,3,0.5,-8)
    Knob.BackgroundColor3=C.knobOff; Knob.BorderSizePixel=0; Knob.ZIndex=14
    Knob.Parent=Rail
    Instance.new("UICorner",Knob).CornerRadius=UDim.new(1,0)

    -- Texte ON/OFF
    local StatusTxt = Instance.new("TextLabel")
    StatusTxt.Size=UDim2.new(0,44,0,11); StatusTxt.Position=UDim2.new(1,-55,1,-13)
    StatusTxt.BackgroundTransparency=1; StatusTxt.Font=Enum.Font.GothamBold
    StatusTxt.Text="OFF"; StatusTxt.TextColor3=C.txt2; StatusTxt.TextSize=9
    StatusTxt.TextXAlignment=Enum.TextXAlignment.Center; StatusTxt.ZIndex=14
    StatusTxt.Parent=Row

    -- Bouton invisible
    local Btn = Instance.new("TextButton")
    Btn.Size=UDim2.new(1,0,1,0); Btn.BackgroundTransparency=1
    Btn.Text=""; Btn.ZIndex=20; Btn.Parent=Row

    local function SetVisual(active)
        local ti = TI(0.2, Enum.EasingStyle.Quad)
        if active then
            Tween(Rail, ti, {BackgroundColor3=C.railOn})
            Tween(Knob, ti, {Position=UDim2.new(0,25,0.5,-8), BackgroundColor3=C.knobOn})
            Tween(AccBar, ti, {BackgroundTransparency=0})
            Tween(IconF, ti, {BackgroundColor3=Color3.fromRGB(25,35,70)})
            Tween(IconTxt, ti, {TextColor3=C.accent})
            Tween(Lbl, ti, {TextColor3=C.accent})
            StatusTxt.Text="ON"; StatusTxt.TextColor3=C.green
        else
            Tween(Rail, ti, {BackgroundColor3=C.railOff})
            Tween(Knob, ti, {Position=UDim2.new(0,3,0.5,-8), BackgroundColor3=C.knobOff})
            Tween(AccBar, ti, {BackgroundTransparency=1})
            Tween(IconF, ti, {BackgroundColor3=C.bg0})
            Tween(IconTxt, ti, {TextColor3=C.txt2})
            Tween(Lbl, ti, {TextColor3=C.txt1})
            StatusTxt.Text="OFF"; StatusTxt.TextColor3=C.txt2
        end
    end

    Btn.MouseEnter:Connect(function() Tween(Row,TI(0.12),{BackgroundColor3=C.bg3}) end)
    Btn.MouseLeave:Connect(function() Tween(Row,TI(0.12),{BackgroundColor3=C.bg2}) end)

    Btn.MouseButton1Click:Connect(function()
        State[key] = not State[key]
        SetVisual(State[key])
        -- Bounce knob
        local bp = State[key] and UDim2.new(0,22,0.5,-8) or UDim2.new(0,5,0.5,-8)
        Tween(Knob, TI(0.07,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Position=bp})
        task.delay(0.09, function()
            local fp = State[key] and UDim2.new(0,25,0.5,-8) or UDim2.new(0,3,0.5,-8)
            Tween(Knob, TI(0.1,Enum.EasingStyle.Quad), {Position=fp})
        end)
        Dispatch[key](State[key])
    end)

    -- Apparition différée
    Row.BackgroundTransparency=1
    task.delay(0.1+order*0.055, function()
        if Row and Row.Parent then
            Tween(Row, TI(0.3,Enum.EasingStyle.Quad), {BackgroundTransparency=0})
        end
    end)

    return SetVisual
end

