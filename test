local minimized = false

local function ToggleMinimize()
    minimized = not minimized
    if minimized then
        Tween(Main, TI(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(0,300,0,52)})
        MinBtn.Text = "□"
    else
        Tween(Main, TI(0.35, Enum.EasingStyle.Back), {Size = UDim2.new(0,300,0,480)})
        MinBtn.Text = "—"
    end
end

MinBtn.MouseButton1Click:Connect(ToggleMinimize)

TrackConn(UserInputService.InputBegan:Connect(function(inp, proc)
    if not proc and inp.KeyCode == Enum.KeyCode.V then
        ToggleMinimize()
    end
end))

