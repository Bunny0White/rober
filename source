	local bb = Instance.new("BillboardGui")
	bb.Name = "__APtag"; bb.Size = UDim2.new(0, 180, 0, 42)
	bb.StudsOffset = Vector3.new(0, 3.8, 0); bb.AlwaysOnTop = true; bb.Parent = head
	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1,0,1,0); bg.BackgroundColor3 = Color3.fromRGB(6,8,16)
	bg.BackgroundTransparency = 0.2; bg.BorderSizePixel = 0; bg.Parent = bb
	Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 8)
	local pill = Instance.new("Frame")
	pill.Size = UDim2.new(0, 3, 0.7, 0); pill.Position = UDim2.new(0, 4, 0.15, 0)
	pill.BackgroundColor3 = C.blue; pill.BorderSizePixel = 0; pill.Parent = bg
	Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)
	local nameLbl = Instance.new("TextLabel")
	nameLbl.Size = UDim2.new(1,-14,0,16); nameLbl.Position = UDim2.new(0,11,0,5)
	nameLbl.BackgroundTransparency=1; nameLbl.Font=Enum.Font.GothamBold
	nameLbl.Text=player.Name; nameLbl.TextColor3=C.t1; nameLbl.TextSize=12
	nameLbl.TextXAlignment=Enum.TextXAlignment.Left; nameLbl.Parent=bg
	-- HP bar track
	local hpTrack = Instance.new("Frame")
	hpTrack.Size = UDim2.new(1,-14,0,4); hpTrack.Position = UDim2.new(0,11,0,23)
	hpTrack.BackgroundColor3 = Color3.fromRGB(22,26,45); hpTrack.BorderSizePixel=0; hpTrack.Parent=bg
	Instance.new("UICorner", hpTrack).CornerRadius = UDim.new(1,0)
	local hpFill = Instance.new("Frame")
	hpFill.Size = UDim2.new(1,0,1,0); hpFill.BackgroundColor3=C.green
	hpFill.BorderSizePixel=0; hpFill.Parent=hpTrack
	Instance.new("UICorner", hpFill).CornerRadius = UDim.new(1,0)
	local hpLbl = Instance.new("TextLabel")
	hpLbl.Size=UDim2.new(0.5,0,0,11); hpLbl.Position=UDim2.new(0,11,0,29)
	hpLbl.BackgroundTransparency=1; hpLbl.Font=Enum.Font.Gotham
	hpLbl.Text="HP: --"; hpLbl.TextColor3=C.green; hpLbl.TextSize=9
	hpLbl.TextXAlignment=Enum.TextXAlignment.Left; hpLbl.Parent=bg
	local distLbl = Instance.new("TextLabel")
	distLbl.Size=UDim2.new(0.45,0,0,11); distLbl.Position=UDim2.new(0.52,0,0,29)
	distLbl.BackgroundTransparency=1; distLbl.Font=Enum.Font.Gotham
	distLbl.Text="0 m"; distLbl.TextColor3=C.t2; distLbl.TextSize=9
	distLbl.TextXAlignment=Enum.TextXAlignment.Right; distLbl.Parent=bg
	local hpConn
	hpConn = RunService.Heartbeat:Connect(function()
		if not (bb and bb.Parent) then if hpConn then hpConn:Disconnect() end return end
		local ph = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if ph then
			local pct = math.clamp(ph.Health / ph.MaxHealth, 0, 1)
			hpFill.Size = UDim2.new(pct, 0, 1, 0)
			hpLbl.Text = "HP: " .. math.floor(pct*100) .. "%"
			local col = Color3.fromRGB(math.floor(255*(1-pct)), math.floor(220*pct+35*(1-pct)), 80*pct)
			hpFill.BackgroundColor3 = col; hpLbl.TextColor3 = col
		end
		local myR = Root(); local thR = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if myR and thR then distLbl.Text = math.floor((myR.Position-thR.Position).Magnitude) .. " m" end
	end)
end
local function RemoveTag(p)
	local c = p.Character; if not c then return end
	local head = c:FindFirstChild("Head"); if not head then return end
	local tag = head:FindFirstChild("__APtag"); if tag then tag:Destroy() end
end
local function ToggleNametags(on)
	if on then
		for _, p in ipairs(Players:GetPlayers()) do MakeTag(p) end
		Track(Players.PlayerAdded:Connect(function(p)
			Track(p.CharacterAdded:Connect(function() task.wait(0.4); if State.Nametags then MakeTag(p) end end))
		end))
		Notify("Nametags", "Nom + HP + distance actifs", "on")
	else
		for _, p in ipairs(Players:GetPlayers()) do RemoveTag(p) end
		Notify("Nametags", "Désactivé", "off")
	end
end

