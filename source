local function MkSlider(parent, label, unit, minV, maxV, defV, cfgKey, order, accent, onChange)
	accent = accent or C.blue
	local Row = Instance.new("Frame")
	Row.Size = UDim2.new(1,0,0,48); Row.BackgroundColor3 = C.card
	Row.BorderSizePixel = 0; Row.LayoutOrder = order; Row.Parent = parent
	Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 9)

	local Lbl = Instance.new("TextLabel")
	Lbl.Size = UDim2.new(0.55,0,0,15); Lbl.Position = UDim2.new(0,10,0,7)
	Lbl.BackgroundTransparency=1; Lbl.Font=Enum.Font.GothamBold; Lbl.Text=label
	Lbl.TextColor3=C.t3; Lbl.TextSize=9; Lbl.TextXAlignment=Enum.TextXAlignment.Left; Lbl.ZIndex=13; Lbl.Parent=Row

	local ValLbl = Instance.new("TextLabel")
	ValLbl.Size=UDim2.new(0,60,0,16); ValLbl.Position=UDim2.new(1,-66,0,6)
	ValLbl.BackgroundColor3=C.shell; ValLbl.BorderSizePixel=0
	ValLbl.Font=Enum.Font.GothamBold; ValLbl.Text=tostring(defV).." "..unit
	ValLbl.TextColor3=accent; ValLbl.TextSize=10; ValLbl.ZIndex=14; ValLbl.Parent=Row
	Instance.new("UICorner",ValLbl).CornerRadius=UDim.new(0,5)

	local TrackBar = Instance.new("Frame")
	TrackBar.Size=UDim2.new(1,-20,0,4); TrackBar.Position=UDim2.new(0,10,0,31)
	TrackBar.BackgroundColor3=C.rOff; TrackBar.BorderSizePixel=0; TrackBar.ZIndex=13; TrackBar.Parent=Row
	Instance.new("UICorner",TrackBar).CornerRadius=UDim.new(1,0)

	local Fill = Instance.new("Frame")
	Fill.Size = UDim2.new(0, 0, 1, 0); Fill.BackgroundColor3 = accent
	Fill.BorderSizePixel = 0; Fill.ZIndex = 14; Fill.Parent = TrackBar
	Instance.new("UICorner", Fill).CornerRadius = UDim.new(1,0)

	local Thumb = Instance.new("Frame")
	Thumb.Size = UDim2.new(0, 10, 0, 10); Thumb.AnchorPoint = Vector2.new(0.5, 0.5)
	Thumb.Position = UDim2.new(0, 0, 0.5, 0); Thumb.BackgroundColor3 = Color3.new(1,1,1)
	Thumb.BorderSizePixel = 0; Thumb.ZIndex = 15; Thumb.Parent = TrackBar
	Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1,0)

	local dragging = false
	local function SetVal(v)
		v = math.clamp(math.floor(v+0.5), minV, maxV)
		if cfgKey then CFG[cfgKey] = v end
		local p = (v-minV)/(maxV-minV)
		Fill.Size=UDim2.new(p,0,1,0); Thumb.Position=UDim2.new(p,0,0.5,0)
		ValLbl.Text=tostring(v).." "..unit
		if cfgKey=="WalkSpeed" and State.Speed then ApplySpeed() end
		if cfgKey=="JumpPower" and State.JumpBoost then ApplyJump() end
		if cfgKey=="FOV" then ApplyFOV() end
		if cfgKey=="TimeOfDay" then ApplyTime() end
		if onChange then onChange(v) end
	end
	SetVal(defV)

	Thumb.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end
	end)
	TrackBar.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			local rel = math.clamp((inp.Position.X - TrackBar.AbsolutePosition.X) / TrackBar.AbsoluteSize.X,0,1)
			SetVal(minV + rel * (maxV - minV))
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local rel = math.clamp((inp.Position.X - TrackBar.AbsolutePosition.X) / TrackBar.AbsoluteSize.X,0,1)
			SetVal(minV + rel * (maxV - minV))
		end
	end)
	Row.MouseEnter:Connect(function() Tw(Row,TI(0.1),{BackgroundColor3=C.hover}) end)
	Row.MouseLeave:Connect(function() Tw(Row,TI(0.1),{BackgroundColor3=C.card}) end)
end

