local Tabs = {}
local CurrentTab = nil

local function SwitchTab(key)
	if CurrentTab == key then return end
	CurrentTab = key
	for _, t in ipairs(Tabs) do
		local active = (t.key == key)
		if active then
			Tw(t.btn, TI(0.16), {BackgroundColor3 = C.active, BackgroundTransparency = 0})
			Tw(t.icon, TI(0.16), {TextColor3 = t.accent})
			Tw(t.lbl, TI(0.16), {TextColor3 = t.accent})
			Tw(t.ind, TI(0.16), {BackgroundTransparency = 0})
			t.page.Visible = true
			PageTitle.Text = t.label:upper()
			Tw(PageTitle, TI(0.1), {TextColor3 = t.accent})
		else
			Tw(t.btn, TI(0.16), {BackgroundTransparency = 1})
			Tw(t.icon, TI(0.16), {TextColor3 = C.t2})
			Tw(t.lbl, TI(0.16), {TextColor3 = C.t2})
			Tw(t.ind, TI(0.16), {BackgroundTransparency = 1})
			t.page.Visible = false
		end
	end
end

local function AddTab(key, icon, label, accent)
	accent = accent or C.blue

	local btn = Instance.new("Frame")
	btn.Size = UDim2.new(0, 50, 0, 52)
	btn.BackgroundColor3 = C.active
	btn.BackgroundTransparency = 1
	btn.BorderSizePixel = 0
	btn.LayoutOrder = #Tabs + 1
	btn.Parent = Sidebar
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

	-- Indicateur actif (barre gauche)
	local ind = Instance.new("Frame")
	ind.Size = UDim2.new(0, 3, 0, 28)
	ind.Position = UDim2.new(0, 0, 0.5, -14)
	ind.BackgroundColor3 = accent
	ind.BorderSizePixel = 0
	ind.BackgroundTransparency = 1
	ind.Parent = btn
	Instance.new("UICorner", ind).CornerRadius = UDim.new(1, 0)

	-- Icône
	local iconLbl = Instance.new("TextLabel")
	iconLbl.Size = UDim2.new(1, 0, 0, 22)
	iconLbl.Position = UDim2.new(0, 0, 0, 6)
	iconLbl.BackgroundTransparency = 1
	iconLbl.Font = Enum.Font.GothamBold
	iconLbl.Text = icon
	iconLbl.TextColor3 = C.t2
	iconLbl.TextSize = 17
	iconLbl.ZIndex = 14
	iconLbl.Parent = btn

	-- Label texte
	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, 0, 0, 14)
	lbl.Position = UDim2.new(0, 0, 0, 30)
	lbl.BackgroundTransparency = 1
	lbl.Font = Enum.Font.Gotham
	lbl.Text = label
	lbl.TextColor3 = C.t2
	lbl.TextSize = 8
	lbl.ZIndex = 14
	lbl.Parent = btn

	-- Zone cliquable
	local clickArea = Instance.new("TextButton")
	clickArea.Size = UDim2.new(1,0,1,0)
	clickArea.BackgroundTransparency = 1
	clickArea.Text = ""
	clickArea.ZIndex = 16
	clickArea.Parent = btn

	-- Page de contenu (ScrollingFrame)
	local page = Instance.new("ScrollingFrame")
	page.Size = UDim2.new(1, 0, 1, 0)
	page.Position = UDim2.new(0, 0, 0, 0)
	page.BackgroundTransparency = 1
	page.BorderSizePixel = 0
	page.ScrollBarThickness = 3
	page.ScrollBarImageColor3 = accent
	page.CanvasSize = UDim2.new(0, 0, 0, 0)
	page.AutomaticCanvasSize = Enum.AutomaticSize.Y
	page.Visible = false
	page.ZIndex = 12
	page.Parent = ContentScroll

	local pageLayout = Instance.new("UIListLayout", page)
	pageLayout.Padding = UDim.new(0, 6)
	pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
	local pagePad = Instance.new("UIPadding", page)
	pagePad.PaddingTop = UDim.new(0, 10)
	pagePad.PaddingLeft = UDim.new(0, 10)
	pagePad.PaddingRight = UDim.new(0, 10)
	pagePad.PaddingBottom = UDim.new(0, 10)

	-- Hover effects
	clickArea.MouseEnter:Connect(function()
		if CurrentTab ~= key then
			Tw(btn, TI(0.12), {BackgroundTransparency = 0.7, BackgroundColor3 = C.hover})
		end
	end)
	clickArea.MouseLeave:Connect(function()
		if CurrentTab ~= key then
			Tw(btn, TI(0.12), {BackgroundTransparency = 1})
		end
	end)
	clickArea.MouseButton1Click:Connect(function()
		SwitchTab(key)
	end)

	local tabData = {key=key, btn=btn, icon=iconLbl, lbl=lbl, ind=ind, page=page, accent=accent, label=label}
	table.insert(Tabs, tabData)
	return page, pageLayout
end

