-- Générique : toggle état + callback
local function connectToggle(btn, setFn, key, onCb, offCb)
    btn.MouseButton1Click:Connect(function()
        states[key] = not states[key]
        setFn(states[key])
        log(key .. " : " .. (states[key] and "ON" or "OFF"))
        if states[key] then
            if onCb  then onCb()  end
        else
            if offCb then offCb() end
        end
    end)
end

connectToggle(espBtn,      espSet,      "ESP",          refreshESP,         refreshESP)
connectToggle(speedBtn,    speedSet,    "Speed",        applySpeed,         applySpeed)
connectToggle(jumpBtn,     jumpSet,     "JumpBoost",    applyJump,          applyJump)
connectToggle(flyBtn,      flySet,      "Fly",          startFly,           stopFly)
connectToggle(godBtn,      godSet,      "GodMode",      startGodMode,       stopGodMode)
connectToggle(infJumpBtn,  infJumpSet,  "InfiniteJump", startInfiniteJump,  stopInfiniteJump)
connectToggle(nametagsBtn, nametagsSet, "Nametags",     refreshNametags,    refreshNametags)

