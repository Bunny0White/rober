    IconLbl.Font                 = Enum.Font.GothamBold
    IconLbl.TextColor3           = C.txt1
    IconLbl.BorderSizePixel      = 0
    IconLbl.ZIndex               = 3
    IconLbl.Parent               = Row
    Instance.new("UICorner", IconLbl).CornerRadius = UDim.new(0,8)

    -- Label principal
    local MainTxt = Instance.new("TextLabel")
    MainTxt.Size                 = UDim2.new(1,-110,0,18)
    MainTxt.Position             = UDim2.new(0,52,0,10)
    MainTxt.BackgroundTransparency = 1
    MainTxt.Font                 = Enum.Font.GothamBold
