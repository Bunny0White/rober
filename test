local isOpen = false

local function ToggleUI()
	isOpen = not isOpen
	Main.Visible = true
	if isOpen then
		Tw(Main, TI(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, TOTAL_W, 0, PANEL_H)})
	else
		Tw(Main, TI(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In),
			{Size = UDim2.new(0, TOTAL_W, 0, 0)})
		task.delay(0.3, function()
			if not isOpen then Main.Visible = false end
		end)
	end
end

TBtnClick.MouseButton1Click:Connect(ToggleUI)

UserInputService.InputBegan:Connect(function(input, gp)
	if not gp and input.KeyCode == Enum.KeyCode.G then
		ToggleUI()
	end
end)

