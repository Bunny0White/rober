-- ──────────────────────────────────────────────────────────────
-- Bouton Toggle → affiche/cache le menu + recharge la liste
-- ──────────────────────────────────────────────────────────────
local function refreshGuiList()
	-- Vider la liste
	for _, c in ipairs(Scroll:GetChildren()) do
		if c:IsA("TextButton") then c:Destroy() end
	end

	local guiChildren = PlayerGui:GetChildren()
	local count = 0

	for _, gui in ipairs(guiChildren) do
		if gui.Name == "GUIInspector" then continue end  -- s'exclure

		count = count + 1
		local btn = Instance.new("TextButton")
		btn.Name             = gui.Name
		btn.Size             = UDim2.new(1, -4, 0, 36)
		btn.BackgroundColor3 = C.surface
		btn.BorderSizePixel  = 0
		btn.Text             = ""
		btn.ZIndex           = 11
		btn.LayoutOrder      = count
		btn.Parent           = Scroll
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)

		-- Icône + nom
		local icon = Instance.new("TextLabel")
		icon.Size              = UDim2.new(0, 28, 1, 0)
		icon.Position          = UDim2.new(0, 4, 0, 0)
		icon.BackgroundTransparency = 1
		icon.Text              = "📦"
		icon.TextSize          = 16
		icon.Font              = Enum.Font.Gotham
		icon.ZIndex            = 12
		icon.Parent            = btn

		local label = Instance.new("TextLabel")
		label.Size             = UDim2.new(1, -38, 1, 0)
		label.Position         = UDim2.new(0, 34, 0, 0)
		label.BackgroundTransparency = 1
		label.Text             = gui.Name .. "  [" .. gui.ClassName .. "]"
		label.TextColor3       = C.text
		label.TextSize         = 12
		label.Font             = Enum.Font.Gotham
		label.TextXAlignment   = Enum.TextXAlignment.Left
		label.TextTruncate     = Enum.TextTruncate.AtEnd
		label.ZIndex           = 12
		label.Parent           = btn

		-- Hover
		btn.MouseEnter:Connect(function()
			btn.BackgroundColor3 = C.border
		end)
		btn.MouseLeave:Connect(function()
			btn.BackgroundColor3 = C.surface
		end)

		-- ── Clic → ouvrir modal d'inspection ──────────────────
		local guiRef = gui   -- capture
		btn.MouseButton1Click:Connect(function()
			openModal(guiRef)
		end)
	end

	-- Mettre à jour la hauteur du canvas
	Scroll.CanvasSize = UDim2.new(0, 0, 0, count * 40)

	if count == 0 then
		local empty = Instance.new("TextLabel")
		empty.Size             = UDim2.new(1, 0, 0, 40)
		empty.BackgroundTransparency = 1
		empty.Text             = "Aucun GUI trouvé"
		empty.TextColor3       = C.subtext
		empty.TextSize         = 12
		empty.Font             = Enum.Font.GothamItalic
		empty.ZIndex           = 11
		empty.Parent           = Scroll
	end
end

