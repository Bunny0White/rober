-- ══════════════════════════════════════════════════════════════════════
local Tabs = {}
local CurrentTab = nil

local function SwitchTab(key)
	if CurrentTab == key then return end
	CurrentTab = key
	for _, t in ipairs(Tabs) do
		local active = (t.key == key)
		if active then
			Tw(t.tab, TI(0.18), {BackgroundColor3 = C.active, BackgroundTransparency = 0})
			Tw(t.tabLbl, TI(0.18), {TextColor3 = C.blue})
			Tw(t.indicator, TI(0.18), {BackgroundTransparency = 0})
			t.page.Visible = true
		else
			Tw(t.tab, TI(0.18), {BackgroundTransparency = 1})
			Tw(t.tabLbl, TI(0.18), {TextColor3 = C.t2})
			Tw(t.indicator, TI(0.18), {BackgroundTransparency = 1})
			t.page.Visible = false
		end
	end
end

