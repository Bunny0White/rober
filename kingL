local function ApplyESP(p)
	if p == LocalPlayer then return end
	local c = p.Character; if not c or c:FindFirstChild("__APesp") then return end
	local hl = Instance.new("Highlight")
	hl.Name = "__APesp"; hl.FillColor = CFG.ESPFill; hl.OutlineColor = CFG.ESPOutline
	hl.FillTransparency = 0.5; hl.OutlineTransparency = 0
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = c
end
local function RemoveESP(p)
	local c = p.Character; if not c then return end
	local hl = c:FindFirstChild("__APesp"); if hl then hl:Destroy() end
end
local function ToggleESP(on)
	if on then
		for _, p in ipairs(Players:GetPlayers()) do ApplyESP(p) end
		Notify("ESP", "Joueurs mis en évidence", "on")
	else
		for _, p in ipairs(Players:GetPlayers()) do RemoveESP(p) end
		Notify("ESP", "Désactivé", "off")
	end
end

local function ToggleRainbowESP(on)
	if RainbowConn then RainbowConn:Disconnect(); RainbowConn = nil end
	if on then
		local t = 0
		RainbowConn = RunService.Heartbeat:Connect(function(dt)
			t = t + dt * 0.5
			local col = Color3.fromHSV(t % 1, 1, 1)
			for _, p in ipairs(Players:GetPlayers()) do
				if p ~= LocalPlayer and p.Character then
					local hl = p.Character:FindFirstChild("__APesp")
					if hl then hl.OutlineColor = col end
				end
			end
		end)
		Notify("Rainbow ESP", "Couleurs animées", "on")
	else Notify("Rainbow ESP", "Désactivé", "off") end
end

local function ToggleTracers(on)
	if TracerConn then TracerConn:Disconnect(); TracerConn = nil end
	for _, line in pairs(TracerLines) do pcall(function() line:Destroy() end) end
	TracerLines = {}
	if on then
		local gui = Instance.new("ScreenGui")
		gui.Name = "__APtracers"; gui.ResetOnSpawn = false; gui.Parent = LocalPlayer.PlayerGui
		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(1,0,1,0); frame.BackgroundTransparency = 1; frame.Parent = gui
		TracerConn = RunService.RenderStepped:Connect(function()
			for _, child in ipairs(frame:GetChildren()) do child:Destroy() end
			local cam = workspace.CurrentCamera
			local screenH = cam.ViewportSize.Y
			for _, p in ipairs(Players:GetPlayers()) do
				if p ~= LocalPlayer and p.Character then
					local root = p.Character:FindFirstChild("HumanoidRootPart")
					if root then
						local screenPos, onScreen = cam:WorldToViewportPoint(root.Position)
						if onScreen then
							local line = Instance.new("Frame")
							local sx = screenPos.X; local sy = screenPos.Y
							local bx = cam.ViewportSize.X / 2; local by = screenH
							local dx = sx - bx; local dy = sy - by
							local len = math.sqrt(dx*dx + dy*dy)
							local ang = math.atan2(dy, dx)
							line.Size = UDim2.new(0, len, 0, 1)
							line.Position = UDim2.new(0, bx, 0, by)
							line.Rotation = math.deg(ang)
							line.AnchorPoint = Vector2.new(0, 0.5)
							line.BackgroundColor3 = C.cyan
							line.BackgroundTransparency = 0.3
							line.BorderSizePixel = 0; line.Parent = frame
						end
					end
				end
			end
		end)
		Notify("Tracers", "Lignes de suivi actives", "on")
	else
		local g = LocalPlayer.PlayerGui:FindFirstChild("__APtracers")
		if g then g:Destroy() end
		Notify("Tracers", "Désactivé", "off")
	end
end

