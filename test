local Dispatch = {
    ESP          = ToggleESP,
    Speed        = ToggleSpeed,
    JumpBoost    = ToggleJump,
    Fly          = ToggleFly,
    GodMode      = ToggleGodMode,
    InfiniteJump = ToggleInfiniteJump,
    Nametags     = ToggleNametags,
}

-- ┌─────────────────────────────────────────────────────────────┐
-- │  RESPAWN — réappliquer les fonctions actives                │
-- └─────────────────────────────────────────────────────────────┘
local function OnCharacterAdded(char)
    char:WaitForChild("Humanoid", 8)
    task.wait(0.6)
    if State.Speed        then ApplySpeed()       end
    if State.JumpBoost    then ApplyJump()        end
    if State.GodMode      then ToggleGodMode(true) end
    if State.Fly          then task.wait(0.2); StartFly() end
    if State.ESP then
        for _, p in ipairs(Players:GetPlayers()) do ApplyESP(p) end
    end
    if State.Nametags then
        for _, p in ipairs(Players:GetPlayers()) do MakeTag(p) end
    end
end

CharConn = TrackConn(LocalPlayer.CharacterAdded:Connect(OnCharacterAdded))

