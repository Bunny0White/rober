    if not tbDragged then
        if panelOpen then ClosePanel() else OpenPanel() end
    end
end)

Track(UserInputService.InputBegan:Connect(function(inp, proc)
    if not proc and inp.KeyCode == Enum.KeyCode.V then
        if panelOpen then ClosePanel() else OpenPanel() end
    end
end))

