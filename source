--  TOGGLE PANEL (bouton + touche V)
-- ════════════════════════════════════════════════════════════════
local panelOpen = false
local PANEL_HEIGHT = 520  -- hauteur complète du panel

local function OpenPanel()
    panelOpen = true
    Main.Visible = true
    Main.Size = UDim2.new(0,320,0,0)
    Tween(Main, TI(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.new(0,320,0,PANEL_HEIGHT)})
    ToggleBtn.Text = "▴  ADMIN PANEL"
    Tween(TBStroke, TI(0.2), {Transparency=0.1})
end

local function ClosePanel()
    panelOpen = false
    Tween(Main, TI(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        {Size = UDim2.new(0,320,0,0)})
    task.delay(0.38, function()
        if not panelOpen then Main.Visible = false end
    end)
    ToggleBtn.Text = "▾  ADMIN PANEL"
    Tween(TBStroke, TI(0.2), {Transparency=0.5})
end

ToggleBtn.MouseButton1Click:Connect(function()
    if not tbDrag then
        if panelOpen then ClosePanel() else OpenPanel() end
    end
end)

Track(UserInputService.InputBegan:Connect(function(inp, proc)
    if not proc and inp.KeyCode==Enum.KeyCode.V then
        if panelOpen then ClosePanel() else OpenPanel() end
    end
end))

