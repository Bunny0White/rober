-- ============================================================
--  DRAG — rendre le panel déplaçable
-- ============================================================
do
    local dragging, dragStart, startPos = false, nil, nil

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
                         input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- ============================================================
--  TOGGLE PANEL (bouton & touche V)
-- ============================================================
local function togglePanel()
    local visible = not frame.Visible
    if visible then
        frame.Visible = true
        frame.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 270, 0, 420)
        }):Play()
    else
        local t = TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0)
        })
        t:Play()
        t.Completed:Connect(function() frame.Visible = false end)
    end
end

toggleBtn.MouseButton1Click:Connect(togglePanel)
closeBtn.MouseButton1Click:Connect(togglePanel)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.V then
        togglePanel()
    end
end)

-- ============================================================
--  FONCTIONNALITÉ 1 — ESP (Highlight)
-- ============================================================
local function removeAllHighlights()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local h = p.Character:FindFirstChild("ESP_Highlight")
            if h then h:Destroy() end
        end
    end
end

local function addHighlight(character)
    if not character then return end
    if character:FindFirstChild("ESP_Highlight") then return end
    local h = Instance.new("Highlight")
    h.Name          = "ESP_Highlight"
    h.FillColor     = Color3.fromRGB(140, 60, 255)
    h.OutlineColor  = Color3.fromRGB(220, 170, 255)
    h.FillTransparency    = 0.4
    h.OutlineTransparency = 0
    h.DepthMode    = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent       = character
end

local function refreshESP()
    if states.ESP then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player then
                if p.Character then addHighlight(p.Character) end
                p.CharacterAdded:Connect(function(char)
                    task.wait(0.5)
                    if states.ESP then addHighlight(char) end
                end)
            end
        end
    else
        removeAllHighlights()
    end
end

-- ============================================================
--  FONCTIONNALITÉ 2 — SPEED
-- ============================================================
local function applySpeed()
    local hum = getHumanoid()
    if hum then
        hum.WalkSpeed = states.Speed and SPEED_ON or SPEED_DEFAULT
    end
end

-- ============================================================
--  FONCTIONNALITÉ 3 — JUMP BOOST
-- ============================================================
local function applyJump()
    local hum = getHumanoid()
    if hum then
        hum.JumpPower = states.JumpBoost and JUMP_ON or JUMP_DEFAULT
    end
end

-- ============================================================
--  FONCTIONNALITÉ 4 — FLY
-- ============================================================
local function startFly()
    local root = getRootPart()
    local hum  = getHumanoid()
    if not root or not hum then return end

    hum.PlatformStand = true

    flyBodyVel = Instance.new("BodyVelocity")
    flyBodyVel.Velocity    = Vector3.zero
    flyBodyVel.MaxForce    = Vector3.new(1e5, 1e5, 1e5)
    flyBodyVel.Parent      = root

    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque  = Vector3.new(1e5, 1e5, 1e5)
    flyBodyGyro.D          = 50
    flyBodyGyro.Parent     = root

    local cam = workspace.CurrentCamera

    flyConn = RunService.Heartbeat:Connect(function()
        if not states.Fly then return end
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Z) then
            dir = dir + cam.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            dir = dir - cam.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Q) then
            dir = dir - cam.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            dir = dir + cam.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            dir = dir + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            dir = dir - Vector3.new(0, 1, 0)
        end

        flyBodyVel.Velocity   = dir.Magnitude > 0 and dir.Unit * FLY_SPEED or Vector3.zero
        flyBodyGyro.CFrame    = cam.CFrame
    end)
end

local function stopFly()
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    if flyBodyVel  then flyBodyVel:Destroy();  flyBodyVel  = nil end
    if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
    local hum = getHumanoid()
    if hum then hum.PlatformStand = false end
end

-- ============================================================
--  FONCTIONNALITÉ 5 — GOD MODE (côté client)
-- ============================================================
local function startGodMode()
    local hum = getHumanoid()
    if not hum then return end

    godConn = hum.HealthChanged:Connect(function(health)
        if states.GodMode and health < hum.MaxHealth then
            hum.Health = hum.MaxHealth
        end
    end)
    log("GodMode activé")
end

local function stopGodMode()
    if godConn then godConn:Disconnect(); godConn = nil end
    log("GodMode désactivé")
end

-- ============================================================
--  FONCTIONNALITÉ 6 — INFINITE JUMP
-- ============================================================
local function startInfiniteJump()
    infiniteConn = UserInputService.JumpRequest:Connect(function()
        if states.InfiniteJump then
            local hum = getHumanoid()
            if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        end
    end)
    log("InfiniteJump activé")
end

local function stopInfiniteJump()
    if infiniteConn then infiniteConn:Disconnect(); infiniteConn = nil end
    log("InfiniteJump désactivé")
end

-- ============================================================
--  FONCTIONNALITÉ 7 — NAMETAGS
-- ============================================================
local function createNametag(p)
    if not p.Character then return end
    local head = p.Character:FindFirstChild("Head")
    if not head then return end

    if nametags[p] then nametags[p]:Destroy() end

    local bb = Instance.new("BillboardGui")
    bb.Name           = "AdminNametag"
    bb.Size           = UDim2.new(0, 120, 0, 30)
    bb.StudsOffset    = Vector3.new(0, 3, 0)
    bb.AlwaysOnTop    = true
    bb.MaxDistance    = 150
    bb.Parent         = head

    local lbl = Instance.new("TextLabel", bb)
    lbl.Size              = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text              = p.DisplayName
    lbl.Font              = Enum.Font.GothamBold
    lbl.TextSize          = 14
    lbl.TextColor3        = Color3.fromRGB(210, 180, 255)
    lbl.TextStrokeTransparency = 0.4
    lbl.TextStrokeColor3  = Color3.fromRGB(0, 0, 0)

    nametags[p] = bb
end

local function removeNametag(p)
    if nametags[p] then
        nametags[p]:Destroy()
        nametags[p] = nil
    end
end

local function refreshNametags()
    if states.Nametags then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player then
                createNametag(p)
                p.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if states.Nametags then createNametag(p) end
                end)
            end
        end
    else
        for _, p in ipairs(Players:GetPlayers()) do
            removeNametag(p)
        end
    end
end

-- ============================================================
--  RÉAPPLICATION APRÈS RESPAWN
-- ============================================================
local function onCharacterAdded()
    task.wait(1)
    applySpeed()
    applyJump()
    if states.Fly          then startFly()         end
    if states.GodMode      then startGodMode()     end
    if states.InfiniteJump then startInfiniteJump() end
    if states.ESP          then refreshESP()       end
    if states.Nametags     then refreshNametags()  end
    log("Personnage respawné — fonctionnalités réappliquées")
end

player.CharacterAdded:Connect(onCharacterAdded)

-- ============================================================
--  GESTION DES NOUVEAUX JOUEURS
-- ============================================================
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function()
        task.wait(0.5)
        if states.ESP      then addHighlight(p.Character) end
        if states.Nametags then createNametag(p)         end
    end)
end)

Players.PlayerRemoving:Connect(function(p)
    removeNametag(p)
end)

