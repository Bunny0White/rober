local notifCount = 0
local function Notify(title, msg, ntype)
    if not State.NotifEnabled then return end
    notifCount = notifCount + 1
    local NC = Color3.fromRGB(99,140,255)
    if ntype=="on"  then NC=Color3.fromRGB(50,220,140)
    elseif ntype=="off" then NC=Color3.fromRGB(255,90,120)
    elseif ntype=="warn" then NC=Color3.fromRGB(255,190,50) end

    local card = Instance.new("Frame")
    card.Size=UDim2.new(1,0,0,0); card.BackgroundColor3=Color3.fromRGB(13,14,26)
    card.BorderSizePixel=0; card.ClipsDescendants=true; card.LayoutOrder=-notifCount
    card.BackgroundTransparency=1; card.Parent=NotifList
    Instance.new("UICorner",card).CornerRadius=UDim.new(0,8)
    local stroke=Instance.new("UIStroke",card); stroke.Color=NC; stroke.Thickness=1; stroke.Transparency=0.6

    local bar=Instance.new("Frame")
    bar.Size=UDim2.new(0,3,1,0); bar.BackgroundColor3=NC; bar.BorderSizePixel=0; bar.Parent=card
    Instance.new("UICorner",bar).CornerRadius=UDim.new(0,4)

    local t1=Instance.new("TextLabel")
    t1.Size=UDim2.new(1,-14,0,16); t1.Position=UDim2.new(0,10,0,7)
    t1.BackgroundTransparency=1; t1.Font=Enum.Font.GothamBold
    t1.Text=title; t1.TextColor3=Color3.fromRGB(200,210,255); t1.TextSize=12
    t1.TextXAlignment=Enum.TextXAlignment.Left; t1.Parent=card

    local t2=Instance.new("TextLabel")
    t2.Size=UDim2.new(1,-14,0,13); t2.Position=UDim2.new(0,10,0,23)
    t2.BackgroundTransparency=1; t2.Font=Enum.Font.Gotham
    t2.Text=msg; t2.TextColor3=Color3.fromRGB(80,88,130); t2.TextSize=10
    t2.TextXAlignment=Enum.TextXAlignment.Left; t2.Parent=card

    Tween(card,TI(0.25,Enum.EasingStyle.Quart),{Size=UDim2.new(1,0,0,44),BackgroundTransparency=0})
    task.delay(2.8, function()
        Tween(card,TI(0.3,Enum.EasingStyle.Quart,Enum.EasingDirection.In),
            {BackgroundTransparency=1,Size=UDim2.new(1,0,0,0)})
        for _,ch in ipairs(card:GetDescendants()) do
            if ch:IsA("TextLabel") then Tween(ch,TI(0.25),{TextTransparency=1}) end
            if ch:IsA("Frame") then Tween(ch,TI(0.25),{BackgroundTransparency=1}) end
            if ch:IsA("UIStroke") then Tween(ch,TI(0.25),{Transparency=1}) end
        end
        task.delay(0.35, function() pcall(function() card:Destroy() end) end)
    end)
end

