    MainTxt.TextColor3           = C.txt1
    MainTxt.TextSize             = 13
    MainTxt.TextXAlignment       = Enum.TextXAlignment.Left
    MainTxt.ZIndex               = 3
    MainTxt.Parent               = Row

    -- Description
    local DescTxt = Instance.new("TextLabel")
    DescTxt.Size                 = UDim2.new(1,-110,0,14)
    DescTxt.Position             = UDim2.new(0,52,0,28)
    DescTxt.BackgroundTransparency = 1
    DescTxt.Font                 = Enum.Font.Gotham
    DescTxt.Text                 = desc
    DescTxt.TextColor3           = C.txt2
    DescTxt.TextSize             = 10
    DescTxt.TextXAlignment       = Enum.TextXAlignment.Left
    DescTxt.ZIndex               = 3
    DescTxt.Parent               = Row

    -- Switch rail
    local Rail = Instance.new("Frame")
    Rail.Name            = "Rail"
    Rail.Size            = UDim2.new(0,48,0,26)
    Rail.Position        = UDim2.new(1,-60,0.5,-13)
    Rail.BackgroundColor3= C.railOff
    Rail.BorderSizePixel = 0
    Rail.ZIndex          = 3
    Rail.Parent          = Row
    Instance.new("UICorner", Rail).CornerRadius = UDim.new(1,0)

    -- Switch knob
    local Knob = Instance.new("Frame")
    Knob.Name            = "Knob"
    Knob.Size            = UDim2.new(0,20,0,20)
    Knob.Position        = UDim2.new(0,3,0.5,-10)
    Knob.BackgroundColor3= C.knobOff
    Knob.BorderSizePixel = 0
    Knob.ZIndex          = 4
    Knob.Parent          = Rail
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1,0)

    -- Indicateur d'état (petit texte ON/OFF)
    local StatusTxt = Instance.new("TextLabel")
    StatusTxt.Size                 = UDim2.new(0,32,0,12)
    StatusTxt.Position             = UDim2.new(1,-62,1,-14)
    StatusTxt.BackgroundTransparency = 1
    StatusTxt.Font                 = Enum.Font.GothamBold
    StatusTxt.Text                 = "OFF"
    StatusTxt.TextColor3           = C.txt2
    StatusTxt.TextSize             = 9
    StatusTxt.TextXAlignment       = Enum.TextXAlignment.Center
    StatusTxt.ZIndex               = 5
    StatusTxt.Parent               = Row

    -- Bouton invisible (clic)
    local Btn = Instance.new("TextButton")
    Btn.Size                = UDim2.new(1,0,1,0)
    Btn.BackgroundTransparency = 1
    Btn.Text                = ""
    Btn.ZIndex              = 10
    Btn.Parent              = Row

    -- Fonction de mise à jour visuelle du switch
    local function SetVisual(active)
        local ti = TI(0.18, Enum.EasingStyle.Quad)
        if active then
            Tween(Rail,  ti, {BackgroundColor3 = C.railOn})
            Tween(Knob,  ti, {Position = UDim2.new(0,25,0.5,-10), BackgroundColor3 = C.knobOn})
            Tween(Accent, ti, {BackgroundTransparency = 0})
            Tween(IconLbl, ti, {BackgroundColor3 = C.accent})
            Tween(MainTxt, ti, {TextColor3 = C.accent})
            StatusTxt.Text      = "ON"
            StatusTxt.TextColor3= C.green
        else
            Tween(Rail,  ti, {BackgroundColor3 = C.railOff})
            Tween(Knob,  ti, {Position = UDim2.new(0,3,0.5,-10), BackgroundColor3 = C.knobOff})
            Tween(Accent, ti, {BackgroundTransparency = 1})
            Tween(IconLbl, ti, {BackgroundColor3 = C.bg0})
            Tween(MainTxt, ti, {TextColor3 = C.txt1})
            StatusTxt.Text       = "OFF"
            StatusTxt.TextColor3 = C.txt2
        end
    end

    -- Hover
    Btn.MouseEnter:Connect(function()
        Tween(Row, TI(0.12), {BackgroundColor3 = C.bg3})
    end)
    Btn.MouseLeave:Connect(function()
        Tween(Row, TI(0.12), {BackgroundColor3 = C.bg2})
    end)

    -- Clic
    Btn.MouseButton1Click:Connect(function()
        State[key] = not State[key]
        SetVisual(State[key])
        -- Petit bounce du knob
        local bouncePos = State[key]
            and UDim2.new(0,22,0.5,-10)
            or  UDim2.new(0,5,0.5,-10)
        Tween(Knob, TI(0.07, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = bouncePos})
        task.delay(0.08, function()
            local finalPos = State[key]
                and UDim2.new(0,25,0.5,-10)
                or  UDim2.new(0,3,0.5,-10)
            Tween(Knob, TI(0.1, Enum.EasingStyle.Quad), {Position = finalPos})
        end)
        Dispatch[key](State[key])
    end)

    -- Animation d'apparition différée
    Row.BackgroundTransparency = 1
    task.delay(0.15 + order * 0.07, function()
        Tween(Row, TI(0.35, Enum.EasingStyle.Quad), {BackgroundTransparency = 0})
    end)

    return SetVisual
end

