-- │  RESPAWN                                                            │
-- └─────────────────────────────────────────────────────────────────────┘
local function OnCharacterAdded(char)
    char:WaitForChild("Humanoid",8); task.wait(0.6)
    if State.Speed        then ApplySpeed()        end
    if State.JumpBoost    then ApplyJump()         end
    if State.GodMode      then ToggleGodMode(true) end
    if State.Fly          then task.wait(0.2); StartFly() end
    if State.NoClip       then ToggleNoClip(true)  end
    if State.ESP          then for _,p in ipairs(Players:GetPlayers()) do ApplyESP(p) end end
    if State.Nametags     then for _,p in ipairs(Players:GetPlayers()) do MakeTag(p) end end
    ApplyFOV()
end
CharConn=Track(LocalPlayer.CharacterAdded:Connect(OnCharacterAdded))

