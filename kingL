--  TOGGLE VISIBILITÉ PANEL  (touche G)
-- ══════════════════════════════════════════════════════════════════════
local panelOpen = false

local function TogglePanel()
	panelOpen = not panelOpen
	if panelOpen then
		Main.Size = UDim2.new(0, TOTAL_W, 0, 0)
		Main.Visible = true
		Tw(Main, TI(0.35, Enum.EasingStyle.Back), {Size = UDim2.new(0, TOTAL_W, 0, PANEL_H)})
		if not CurrentTab then SwitchTab("farm") end
		Tw(TArrow, TI(0.2), {TextColor3 = C.green})
	else
		Tw(Main, TI(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, TOTAL_W, 0, 0)})
		task.wait(0.32)
		Main.Visible = false
		Tw(TArrow, TI(0.2), {TextColor3 = C.gold})
	end
end

-- Clic sur TBtn
TBtnClick.MouseButton1Click:Connect(function()
	if not tbDrag then TogglePanel() end
end)

-- Touche G
Track(UserInputService.InputBegan:Connect(function(inp, proc)
	if proc then return end
	if inp.KeyCode == Enum.KeyCode.G then TogglePanel() end
end))

