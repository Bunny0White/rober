local function FullCleanup()
    local h=Hum()
    if h then h.WalkSpeed=16; h.JumpPower=50; h.PlatformStand=false end
    if FlyConn     then FlyConn:Disconnect()     FlyConn=nil     end
    if FlyBV       then FlyBV:Destroy()          FlyBV=nil       end
    if FlyBG       then FlyBG:Destroy()          FlyBG=nil       end
    if GodConn     then GodConn:Disconnect()     GodConn=nil     end
    if InfJumpConn then InfJumpConn:Disconnect() InfJumpConn=nil end
    if NoClipConn  then NoClipConn:Disconnect()  NoClipConn=nil  end
    if CharConn    then CharConn:Disconnect()     CharConn=nil    end
    Lighting.Brightness     = OrigLighting.Brightness
    Lighting.ClockTime      = OrigLighting.ClockTime
    Lighting.FogEnd         = OrigLighting.FogEnd
    Lighting.FogStart       = OrigLighting.FogStart
    Lighting.GlobalShadows  = OrigLighting.GlobalShadows
    Lighting.Ambient        = OrigLighting.Ambient
    Lighting.OutdoorAmbient = OrigLighting.OutdoorAmbient
    local cam=workspace.CurrentCamera
    if cam then cam.FieldOfView=70 end
    for _,p in ipairs(Players:GetPlayers()) do
        local c=p.Character
        if c then
            local hl=c:FindFirstChild("__APesp"); if hl then hl:Destroy() end
            local head=c:FindFirstChild("Head")
            if head then local tag=head:FindFirstChild("__APtag"); if tag then tag:Destroy() end end
        end
    end
    for _,conn in ipairs(Connections) do pcall(function() conn:Disconnect() end) end
    Connections={}
    for k in pairs(State) do State[k]=false end
    State.NotifEnabled=true
    pcall(function() NotifGui:Destroy() end)
end

