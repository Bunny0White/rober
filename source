-- ┌─────────────────────────────────────────────────────────────┐
-- │  ÉTAT GLOBAL                                                │
-- └─────────────────────────────────────────────────────────────┘
local State = {
    ESP          = false,
    Speed        = false,
    JumpBoost    = false,
    Fly          = false,
    GodMode      = false,
    InfiniteJump = false,
    Nametags     = false,
}

-- Connexions et objets
local Connections  = {}
local FlyConn      = nil
local FlyBV        = nil
local FlyBG        = nil
local GodConn      = nil
local InfJumpConn  = nil
local CharConn     = nil

-- ┌─────────────────────────────────────────────────────────────┐
-- │  UTILITAIRES                                                │
-- └─────────────────────────────────────────────────────────────┘
local function Char()  return LocalPlayer.Character end
local function Hum()   local c=Char(); return c and c:FindFirstChildOfClass("Humanoid") end
local function Root()  local c=Char(); return c and c:FindFirstChild("HumanoidRootPart") end

local function Track(conn) table.insert(Connections, conn) return conn end

local function TI(t, style, dir)
    return TweenInfo.new(t,
        style or Enum.EasingStyle.Quart,
        dir   or Enum.EasingDirection.Out)
end

local function Tween(obj, info, props)
    if obj and obj.Parent then
        TweenService:Create(obj, info, props):Play()
    end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  CLEANUP COMPLET                                            │
-- └─────────────────────────────────────────────────────────────┘
local function FullCleanup()
    local h = Hum()
    if h then
        h.WalkSpeed     = 16
        h.JumpPower     = 50
        h.PlatformStand = false
    end
    if FlyConn     then FlyConn:Disconnect()    FlyConn    = nil end
    if FlyBV       then FlyBV:Destroy()         FlyBV      = nil end
    if FlyBG       then FlyBG:Destroy()         FlyBG      = nil end
    if GodConn     then GodConn:Disconnect()    GodConn    = nil end
    if InfJumpConn then InfJumpConn:Disconnect() InfJumpConn = nil end
    if CharConn    then CharConn:Disconnect()   CharConn   = nil end

    for _, p in ipairs(Players:GetPlayers()) do
        local c = p.Character
        if c then
            local hl = c:FindFirstChild("__APesp")
            if hl then hl:Destroy() end
            local head = c:FindFirstChild("Head")
            if head then
                local tag = head:FindFirstChild("__APtag")
                if tag then tag:Destroy() end
            end
        end
    end
    for _, conn in ipairs(Connections) do pcall(function() conn:Disconnect() end) end
    Connections = {}
    for k in pairs(State) do State[k] = false end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  1. ESP                                                     │
-- └─────────────────────────────────────────────────────────────┘
local function ApplyESP(player)
    if player == LocalPlayer then return end
    local c = player.Character; if not c then return end
    if c:FindFirstChild("__APesp") then return end
    local hl = Instance.new("Highlight")
    hl.Name                = "__APesp"
    hl.FillColor           = Color3.fromRGB(255, 60, 100)
    hl.OutlineColor        = Color3.fromRGB(255, 180, 200)
    hl.FillTransparency    = 0.55
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent              = c
end

local function RemoveESP(player)
    local c = player.Character; if not c then return end
    local hl = c:FindFirstChild("__APesp"); if hl then hl:Destroy() end
end

local function ToggleESP(on)
    if on then
        for _, p in ipairs(Players:GetPlayers()) do ApplyESP(p) end
        Track(Players.PlayerAdded:Connect(function(p)
            Track(p.CharacterAdded:Connect(function()
                task.wait(0.5); if State.ESP then ApplyESP(p) end
            end))
        end))
    else
        for _, p in ipairs(Players:GetPlayers()) do RemoveESP(p) end
    end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  2. SPEED                                                   │
-- └─────────────────────────────────────────────────────────────┘
local function ApplySpeed()
    local h = Hum(); if h then h.WalkSpeed = CFG.WalkSpeed end
end
local function ToggleSpeed(on)
    if on then ApplySpeed()
    else local h=Hum(); if h then h.WalkSpeed=16 end end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  3. JUMP BOOST                                              │
-- └─────────────────────────────────────────────────────────────┘
local function ApplyJump()
    local h = Hum(); if h then h.JumpPower = CFG.JumpPower end
end
local function ToggleJump(on)
    if on then ApplyJump()
    else local h=Hum(); if h then h.JumpPower=50 end end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  4. FLY                                                     │
-- └─────────────────────────────────────────────────────────────┘
local function StartFly()
    local r=Root(); local h=Hum(); if not r or not h then return end
    h.PlatformStand = true
    FlyBV = Instance.new("BodyVelocity")
    FlyBV.Velocity = Vector3.zero
    FlyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
    FlyBV.Parent   = r
    FlyBG = Instance.new("BodyGyro")
    FlyBG.MaxTorque = Vector3.new(1e5,1e5,1e5)
    FlyBG.CFrame    = r.CFrame
    FlyBG.P         = 1e4
    FlyBG.Parent    = r
    local cam = workspace.CurrentCamera
    FlyConn = RunService.Heartbeat:Connect(function()
        if not State.Fly or not FlyBV or not FlyBG then return end
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Z) then dir=dir+cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S)                                                then dir=dir-cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Q) then dir=dir-cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D)                                               then dir=dir+cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.yAxis end
        FlyBV.Velocity = (dir.Magnitude>0 and dir.Unit or Vector3.zero)*CFG.FlySpeed
        FlyBG.CFrame   = cam.CFrame
    end)
end

local function StopFly()
    if FlyConn then FlyConn:Disconnect() FlyConn=nil end
    if FlyBV   then FlyBV:Destroy()   FlyBV=nil  end
    if FlyBG   then FlyBG:Destroy()   FlyBG=nil  end
    local h=Hum(); if h then h.PlatformStand=false end
end

local function ToggleFly(on)
    if on then StartFly() else StopFly() end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  5. GOD MODE                                                │
-- └─────────────────────────────────────────────────────────────┘
local function ToggleGodMode(on)
    if GodConn then GodConn:Disconnect() GodConn=nil end
    if on then
        GodConn = RunService.Heartbeat:Connect(function()
            local h=Hum(); if h and h.Health<h.MaxHealth then h.Health=h.MaxHealth end
        end)
    end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  6. INFINITE JUMP                                           │
-- └─────────────────────────────────────────────────────────────┘
local function ToggleInfiniteJump(on)
    if InfJumpConn then InfJumpConn:Disconnect() InfJumpConn=nil end
    if on then
        InfJumpConn = Track(UserInputService.JumpRequest:Connect(function()
            local h=Hum(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
        end))
    end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  7. NAMETAGS                                                │
-- └─────────────────────────────────────────────────────────────┘
local function MakeTag(player)
    if player==LocalPlayer then return end
    local c=player.Character; if not c then return end
    local head=c:FindFirstChild("Head"); if not head then return end
    if head:FindFirstChild("__APtag") then return end
    local bb=Instance.new("BillboardGui")
    bb.Name="__APtag"; bb.Size=UDim2.new(0,150,0,30)
    bb.StudsOffset=Vector3.new(0,3.2,0); bb.AlwaysOnTop=true; bb.Parent=head
    local tx=Instance.new("TextLabel")
    tx.Size=UDim2.new(1,0,1,0); tx.BackgroundTransparency=1
    tx.Font=Enum.Font.GothamBold; tx.Text="✦ "..player.Name
    tx.TextColor3=Color3.fromRGB(255,230,100)
    tx.TextStrokeTransparency=0.3; tx.TextStrokeColor3=Color3.new(0,0,0)
    tx.TextSize=13; tx.Parent=bb
end

local function RemoveTag(player)
    local c=player.Character; if not c then return end
    local head=c:FindFirstChild("Head"); if not head then return end
    local tag=head:FindFirstChild("__APtag"); if tag then tag:Destroy() end
end

local function ToggleNametags(on)
    if on then
        for _,p in ipairs(Players:GetPlayers()) do MakeTag(p) end
        Track(Players.PlayerAdded:Connect(function(p)
            Track(p.CharacterAdded:Connect(function()
                task.wait(0.5); if State.Nametags then MakeTag(p) end
            end))
        end))
    else
        for _,p in ipairs(Players:GetPlayers()) do RemoveTag(p) end
    end
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  DISPATCH                                                   │
-- └─────────────────────────────────────────────────────────────┘
local Dispatch = {
    ESP=ToggleESP, Speed=ToggleSpeed, JumpBoost=ToggleJump,
    Fly=ToggleFly, GodMode=ToggleGodMode,
    InfiniteJump=ToggleInfiniteJump, Nametags=ToggleNametags,
}

-- ┌─────────────────────────────────────────────────────────────┐
-- │  RESPAWN                                                    │
-- └─────────────────────────────────────────────────────────────┘
local function OnCharacterAdded(char)
    char:WaitForChild("Humanoid",8); task.wait(0.6)
    if State.Speed        then ApplySpeed()        end
    if State.JumpBoost    then ApplyJump()         end
    if State.GodMode      then ToggleGodMode(true) end
    if State.Fly          then task.wait(0.2); StartFly() end
    if State.ESP          then for _,p in ipairs(Players:GetPlayers()) do ApplyESP(p) end end
    if State.Nametags     then for _,p in ipairs(Players:GetPlayers()) do MakeTag(p) end end
end
CharConn = Track(LocalPlayer.CharacterAdded:Connect(OnCharacterAdded))

