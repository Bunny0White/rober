-- ──────────────────────────────────────────────────────────────
-- Utilitaire : rendre un Frame déplaçable
-- ──────────────────────────────────────────────────────────────
local function makeDraggable(frame, handle)
	handle = handle or frame
	local dragging, dragInput, dragStart, startPos

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging   = true
			dragStart  = input.Position
			startPos   = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	handle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input == dragInput then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end

-- ──────────────────────────────────────────────────────────────
-- Utilitaire : copier dans le presse-papier (via setclipboard)
-- ──────────────────────────────────────────────────────────────
local function copyToClipboard(text)
	local ok, err = pcall(function()
		setclipboard(text)
	end)
	if not ok then
		-- Fallback si setclipboard indisponible (Studio sans exploit)
		warn("[GUIInspector] setclipboard non disponible : " .. tostring(err))
	end
end

-- ──────────────────────────────────────────────────────────────
-- Utilitaire : sérialiser les propriétés d'un objet
-- ──────────────────────────────────────────────────────────────
local PROPERTIES = {
	"Name", "ClassName", "Visible", "ZIndex", "Size", "Position",
	"AnchorPoint", "BackgroundColor3", "BackgroundTransparency",
	"BorderSizePixel", "Text", "TextColor3", "TextSize", "Font",
	"Image", "ImageColor3", "ScaleType", "Rotation",
	"AutomaticSize", "SizeConstraint", "ClipsDescendants",
	"Active", "Selectable", "Modal",
}

local function serializeValue(v)
	local t = typeof(v)
	if t == "string"  then return '"' .. v .. '"' end
	if t == "boolean" then return tostring(v) end
	if t == "number"  then return string.format("%.4g", v) end
	if t == "UDim2"   then
		return string.format("UDim2.new(%.3g,%.3g, %.3g,%.3g)",
			v.X.Scale, v.X.Offset, v.Y.Scale, v.Y.Offset)
	end
	if t == "UDim"    then return string.format("UDim.new(%.3g,%.3g)", v.Scale, v.Offset) end
	if t == "Vector2" then return string.format("Vector2.new(%.3g,%.3g)", v.X, v.Y) end
	if t == "Color3"  then
		return string.format("Color3.fromRGB(%d,%d,%d)",
			math.round(v.R*255), math.round(v.G*255), math.round(v.B*255))
	end
	if t == "EnumItem" then return tostring(v) end
	return tostring(v)
end

local function buildReport(obj)
	local lines = {}
	local function add(s) lines[#lines+1] = s end

	-- En-tête objet
	add("══════════════════════════════════════")
	add(string.format("▶  %s  [%s]", obj.Name, obj.ClassName))
	add("══════════════════════════════════════")

	-- Propriétés
	add("── Propriétés ──")
	for _, prop in ipairs(PROPERTIES) do
		local ok, val = pcall(function() return obj[prop] end)
		if ok and val ~= nil then
			add(string.format("  %-26s = %s", prop, serializeValue(val)))
		end
	end

	-- Parent
	add("")
	add("── Parent ──")
	if obj.Parent then
		add(string.format("  Name      = %q", obj.Parent.Name))
		add(string.format("  ClassName = %s", obj.Parent.ClassName))
		local okPos, pPos = pcall(function() return obj.Parent.Position end)
		if okPos then
			add(string.format("  Position  = %s", serializeValue(pPos)))
		end
	else
		add("  (pas de parent)")
	end

	-- Enfants
	add("")
	add("── Enfants ──")
	local children = obj:GetChildren()
	if #children == 0 then
		add("  (aucun enfant)")
	else
		for _, child in ipairs(children) do
			add(string.format("  • %-20s [%s]", child.Name, child.ClassName))
		end
	end

	add("══════════════════════════════════════")
	return table.concat(lines, "\n")
end

