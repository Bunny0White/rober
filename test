        Btn.BackgroundTransparency = 1
        Btn.Text                = ""
        Btn.Parent              = Row

        -- Animation du switch
        local function SetSwitch(active)
            local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad)
            if active then
                TweenService:Create(SwitchBg, tweenInfo, {BackgroundColor3 = Color3.fromRGB(70, 120, 255)}):Play()
