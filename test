-- ┌─────────────────────────────────────────────────────────────┐
-- │  UTILITAIRES                                                │
-- └─────────────────────────────────────────────────────────────┘
local function Char()    return LocalPlayer.Character end
local function Hum()     local c=Char(); return c and c:FindFirstChildOfClass("Humanoid") end
local function Root()    local c=Char(); return c and c:FindFirstChild("HumanoidRootPart") end

local function TrackConn(conn)
    table.insert(Connections, conn)
    return conn
end

local function TI(t, style, dir)
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    return TweenInfo.new(t, style, dir)
end

local function Tween(obj, info, props)
    TweenService:Create(obj, info, props):Play()
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  RESET COMPLET — tout remettre à la normale                 │
-- └─────────────────────────────────────────────────────────────┘
local function FullCleanup()
    print("[AdminPanel] ── Nettoyage complet en cours...")

    -- Désactiver toutes les fonctionnalités
    -- Speed
    local h = Hum()
    if h then
        h.WalkSpeed = 16
        h.JumpPower = 50
        h.PlatformStand = false
    end

    -- Fly
    if FlyConn then FlyConn:Disconnect() FlyConn = nil end
    if FlyBV   then FlyBV:Destroy()   FlyBV  = nil end
    if FlyBG   then FlyBG:Destroy()   FlyBG  = nil end

    -- GodMode
    if GodConn then GodConn:Disconnect() GodConn = nil end

    -- InfiniteJump
    if InfJumpConn then InfJumpConn:Disconnect() InfJumpConn = nil end

    -- CharacterAdded
    if CharConn then CharConn:Disconnect() CharConn = nil end

    -- ESP
    for _, p in ipairs(Players:GetPlayers()) do
        local c = p.Character
        if c then
            local hl = c:FindFirstChild("__APesp")
            if hl then hl:Destroy() end
        end
    end

    -- Nametags
    for _, p in ipairs(Players:GetPlayers()) do
        local c = p.Character
        if c then
            local head = c:FindFirstChild("Head")
            if head then
                local tag = head:FindFirstChild("__APtag")
                if tag then tag:Destroy() end
            end
        end
    end

    -- Toutes les autres connexions
    for _, conn in ipairs(Connections) do
        pcall(function() conn:Disconnect() end)
    end
    Connections = {}

    -- Remettre l'état
    for k in pairs(State) do
        if k ~= "PanelOpen" then State[k] = false end
    end

    print("[AdminPanel] ── Nettoyage terminé. Tout est remis à la normale.")
end

-- ┌─────────────────────────────────────────────────────────────┐
-- │  1. ESP                                                     │
-- └─────────────────────────────────────────────────────────────┘
local function ApplyESP(player)
    if player == LocalPlayer then return end
    local c = player.Character
    if not c then return end
    if c:FindFirstChild("__APesp") then return end
    local hl = Instance.new("Highlight")
    hl.Name                = "__APesp"
    hl.FillColor           = Color3.fromRGB(255, 60, 100)
    hl.OutlineColor        = Color3.fromRGB(255, 180, 200)
    hl.FillTransparency    = 0.55
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent              = c
end

local function RemoveESP(player)
    local c = player.Character
    if c then
        local hl = c:FindFirstChild("__APesp")
        if hl then hl:Destroy() end
    end
end

local function ToggleESP(on)
    if on then
        for _, p in ipairs(Players:GetPlayers()) do ApplyESP(p) end
        TrackConn(Players.PlayerAdded:Connect(function(p)
            TrackConn(p.CharacterAdded:Connect(function()
                task.wait(0.5)
                if State.ESP then ApplyESP(p) end
            end))
        end))
        print("[AdminPanel] ESP ON")
    else
        for _, p in ipairs(Players:GetPlayers()) do RemoveESP(p) end
        print("[AdminPanel] ESP OFF")
    end
end

