local Tabs = {}
local CurrentTab = nil

local function SwitchTab(key)
	if CurrentTab == key then return end
	CurrentTab = key
	for _, t in ipairs(Tabs) do
		local active = (t.key == key)
		if active then
			Tw(t.btn, TI(0.16), {BackgroundColor3 = C.active, BackgroundTransparency = 0})
			Tw(t.icon, TI(0.16), {TextColor3 = t.accent})
			Tw(t.lbl, TI(0.16), {TextColor3 = t.accent})
			Tw(t.ind, TI(0.16), {BackgroundTransparency = 0})
			t.page.Visible = true
			PageTitle.Text = t.label:upper()
			Tw(PageTitle, TI(0.1), {TextColor3 = t.accent})
		else
			Tw(t.btn, TI(0.16), {BackgroundTransparency = 1})
			Tw(t.icon, TI(0.16), {TextColor3 = C.t2})
			Tw(t.lbl, TI(0.16), {TextColor3 = C.t2})
			Tw(t.ind, TI(0.16), {BackgroundTransparency = 1})
			t.page.Visible = false
		end
	end
end

local function AddTab(key, icon, label, accent)
	accent = accent or C.blue

	local btn = Instance.new("Frame")
	btn.Size = UDim2.new(0, 50, 0, 52)    -- taille ajustée pour sidebar 58px
	btn.BackgroundColor3 = C.active; btn.BackgroundTransparency = 1
	btn.BorderSizePixel = 0; btn.LayoutOrder = #Tabs + 1
	btn.ZIndex = 14; btn.Parent = Sidebar
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 9)

	-- Indicateur DROITE (puisque sidebar est à gauche, la bordure active est à droite)
	local ind = Instance.new("Frame")
	ind.Size = UDim2.new(0, 2, 0, 26); ind.Position = UDim2.new(1, -2, 0.5, -13)
	ind.BackgroundColor3 = accent; ind.BackgroundTransparency = 1
	ind.BorderSizePixel = 0; ind.ZIndex = 16; ind.Parent = btn
	Instance.new("UICorner", ind).CornerRadius = UDim.new(1, 0)

	local iconLbl = Instance.new("TextLabel")
	iconLbl.Size = UDim2.new(1, 0, 0, 24); iconLbl.Position = UDim2.new(0, 0, 0, 6)
	iconLbl.BackgroundTransparency = 1; iconLbl.Font = Enum.Font.GothamBold
	iconLbl.Text = icon; iconLbl.TextSize = 17; iconLbl.TextColor3 = C.t2
	iconLbl.ZIndex = 15; iconLbl.Parent = btn

	local subLbl = Instance.new("TextLabel")
	subLbl.Size = UDim2.new(1, 0, 0, 13); subLbl.Position = UDim2.new(0, 0, 0, 30)
	subLbl.BackgroundTransparency = 1; subLbl.Font = Enum.Font.GothamBold
	subLbl.Text = label:sub(1,4):upper(); subLbl.TextSize = 7; subLbl.TextColor3 = C.t2
	subLbl.ZIndex = 15; subLbl.Parent = btn

	local clickZ = Instance.new("TextButton")
	clickZ.Size = UDim2.new(1,0,1,0); clickZ.BackgroundTransparency = 1
	clickZ.Text = ""; clickZ.ZIndex = 20; clickZ.Parent = btn

	local page = Instance.new("ScrollingFrame")
	page.Size = UDim2.new(1, 0, 1, 0)
	page.BackgroundTransparency = 1; page.BorderSizePixel = 0
	page.ScrollBarThickness = 3; page.ScrollBarImageColor3 = accent
	page.CanvasSize = UDim2.new(0, 0, 0, 0)
	page.Visible = false; page.ZIndex = 11; page.Parent = ContentScroll

	local pl = Instance.new("UIListLayout", page)
	pl.Padding = UDim.new(0, 0); pl.SortOrder = Enum.SortOrder.LayoutOrder
	pl.HorizontalAlignment = Enum.HorizontalAlignment.Center
	local pp = Instance.new("UIPadding", page)
	pp.PaddingTop = UDim.new(0, 10); pp.PaddingBottom = UDim.new(0, 14)
	pp.PaddingLeft = UDim.new(0, 12); pp.PaddingRight = UDim.new(0, 12)
	pl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		page.CanvasSize = UDim2.new(0, 0, 0, pl.AbsoluteContentSize.Y + 24)
	end)

	local entry = {key=key, btn=btn, icon=iconLbl, lbl=subLbl, ind=ind, page=page, label=label, accent=accent}
	table.insert(Tabs, entry)

	clickZ.MouseButton1Click:Connect(function() SwitchTab(key) end)
	clickZ.MouseEnter:Connect(function()
		if CurrentTab ~= key then Tw(btn, TI(0.12), {BackgroundTransparency = 0.6}) end
	end)
	clickZ.MouseLeave:Connect(function()
		if CurrentTab ~= key then Tw(btn, TI(0.12), {BackgroundTransparency = 1}) end
	end)

	return page
end

