-- Fonction pour créer un bouton cible
local function CreateTargetButton(parent, name, isBoss)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -6, 0, 26)
	btn.BackgroundColor3 = isBoss and Color3.fromRGB(40, 20, 20) or C.card
	btn.BorderSizePixel = 0
	btn.Text = ""
	btn.Parent = parent
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

	local txt = Instance.new("TextLabel")
	txt.Size = UDim2.new(1, -10, 1, 0)
	txt.Position = UDim2.new(0, 6, 0, 0)
	txt.BackgroundTransparency = 1
	txt.Font = Enum.Font.Gotham
	txt.Text = (isBoss and "👑 " or "⚔ ") .. name
	txt.TextColor3 = isBoss and C.red or C.t1
	txt.TextSize = 11
	txt.TextXAlignment = Enum.TextXAlignment.Left
	txt.Parent = btn

	btn.MouseButton1Click:Connect(function()
		FarmTargetName = name
		FarmTargetIsBoss = isBoss
		UpdateFarmStatus("🎯 Cible: " .. name)
	end)
end

-- Refresh liste mobs/boss
local function RefreshTargetList()
	for _, c in ipairs(targetScroll:GetChildren()) do
		if c:IsA("TextButton") then c:Destroy() end
	end

	for _, mob in ipairs(GetMobNames()) do
		CreateTargetButton(targetScroll, mob.name, false)
	end

	for _, boss in ipairs(GetBossNames()) do
		CreateTargetButton(targetScroll, boss.name, true)
	end
end

RefreshTargetList()

