--  TOGGLE PANEL (bouton + touche V)
-- ════════════════════════════════════════════════════════════════════════
local panelOpen = false

local function OpenPanel()
    panelOpen = true
    Main.Visible = true
    Main.Size = UDim2.new(0, PANEL_W, 0, 0)
    Tween(Main, TI(0.42, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, PANEL_W, 0, PANEL_H)})
    TBArrow.Text = "▴"
    Tween(TBS, TI(0.2), {Transparency = 0.1})
end

local function ClosePanel()
    panelOpen = false
    Tween(Main, TI(0.32, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        {Size = UDim2.new(0, PANEL_W, 0, 0)})
    task.delay(0.35, function()
        if not panelOpen then Main.Visible = false end
    end)
    TBArrow.Text = "▾"
    Tween(TBS, TI(0.2), {Transparency = 0.55})
end

