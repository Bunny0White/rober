-- On garde une référence pour n'avoir qu'une modale à la fois (optionnel)
local activeModal = nil

function openModal(guiObj)
	-- Fermer la précédente
	if activeModal and activeModal.Parent then
		activeModal:Destroy()
	end

	local report = buildReport(guiObj)

	-- Fond semi-transparent (optionnel, commentez si gênant)
	-- On n'en met pas pour ne pas bloquer l'interaction avec le jeu

	local Modal = Instance.new("Frame")
	Modal.Name             = "InspectModal_" .. guiObj.Name
	Modal.Size             = UDim2.new(0, 480, 0, 460)
	Modal.Position         = UDim2.new(0.5, -240, 0.5, -230)
	Modal.BackgroundColor3 = C.bg
	Modal.BorderSizePixel  = 0
	Modal.ZIndex           = 20
	Modal.Parent           = ScreenGui
	Instance.new("UICorner", Modal).CornerRadius = UDim.new(0, 12)
	local modalStroke = Instance.new("UIStroke", Modal)
	modalStroke.Color     = C.accent
	modalStroke.Thickness = 1.5

	activeModal = Modal

	-- Barre de titre (handle)
	local TitleBar = Instance.new("Frame")
	TitleBar.Name             = "TitleBar"
	TitleBar.Size             = UDim2.new(1, 0, 0, 40)
	TitleBar.BackgroundColor3 = C.surface
	TitleBar.BorderSizePixel  = 0
	TitleBar.ZIndex           = 21
	TitleBar.Parent           = Modal
	Instance.new("UICorner", TitleBar).CornerRadius = UDim.new(0, 12)

	local TitleText = Instance.new("TextLabel")
	TitleText.Size           = UDim2.new(1, -80, 1, 0)
