local function LogError(msg, trace)
    table.insert(ErrorLog, 1, {
        message = msg,
        trace = trace,
        time = os.date("%X")
    })
    if #ErrorLog > 50 then table.remove(ErrorLog, #ErrorLog) end -- Limite à 50 erreurs

    -- Mise à jour de l'affichage
    for _, child in ipairs(ErrorList:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    for i, err in ipairs(ErrorLog) do
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 60)
        frame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        frame.BorderSizePixel = 0
        frame.Parent = ErrorList

        local timeLabel = Instance.new("TextLabel")
        timeLabel.Size = UDim2.new(0.2, 0, 0, 20)
        timeLabel.Position = UDim2.new(0, 5, 0, 5)
        timeLabel.Text = err.time
        timeLabel.TextColor3 = Color3.fromRGB(150, 150, 200)
        timeLabel.Font = Enum.Font.Gotham
        timeLabel.TextSize = 10
        timeLabel.BackgroundTransparency = 1
        timeLabel.Parent = frame

        local msgLabel = Instance.new("TextLabel")
        msgLabel.Size = UDim2.new(1, -10, 0, 20)
        msgLabel.Position = UDim2.new(0, 5, 0, 25)
        msgLabel.Text = err.message
        msgLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        msgLabel.Font = Enum.Font.GothamBold
        msgLabel.TextSize = 12
        msgLabel.BackgroundTransparency = 1
        msgLabel.TextWrapped = true
        msgLabel.Parent = frame

        local traceLabel = Instance.new("TextLabel")
        traceLabel.Size = UDim2.new(1, -10, 0, 15)
        traceLabel.Position = UDim2.new(0, 5, 0, 45)
        traceLabel.Text = string.sub(err.trace, 1, 100) .. (string.len(err.trace) > 100 and "..." or "")
        traceLabel.TextColor3 = Color3.fromRGB(180, 180, 220)
        traceLabel.Font = Enum.Font.Gotham
        traceLabel.TextSize = 9
        traceLabel.BackgroundTransparency = 1
        traceLabel.TextWrapped = true
        traceLabel.Parent = frame
    end
end

-- Capture des erreurs
local function SafeCall(func)
    return xpcall(func, function(err)
        LogError("ERREUR: " .. err, debug.traceback())
        warn("AdminPanel Error: " .. err)
    end)
end

