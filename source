--[[
    ADMIN PANEL INSTALLER v1.0
    ✅ Crée automatiquement le script dans StarterPlayerScripts
    ✅ Gère les dépendances (ScreenGui, etc.)
    ✅ Évite les doublons
    ✅ Compatible avec les respawns
]]
local Players = game:GetService("Players")
local ServerScriptService = game:GetService("ServerScriptService")
local StarterPlayerScripts = game:GetService("StarterPlayerScripts")
local RunService = game:GetService("RunService")

-- ========== CONFIG ==========
local SCRIPT_NAME = "AdminPanelV5"  -- Nom du script principal
local SCRIPT_CODE = [[
--[[ CODE DU PANEL ICI (copiez-collez le code complet du panel que je vous ai donné précédemment) ]]
]]

-- ========== FONCTIONS D'INSTALLATION ==========
local function CreateAdminPanel(player)
    -- Vérifier si le script existe déjà
    if player:FindFirstChild("PlayerScripts") then
        local playerScripts = player:FindFirstChild("PlayerScripts")
        if playerScripts:FindFirstChild(SCRIPT_NAME) then
            playerScripts:FindFirstChild(SCRIPT_NAME):Destroy()
        end
    end

    -- Créer le script dans StarterPlayerScripts (pour les nouveaux joueurs)
    if not StarterPlayerScripts:FindFirstChild(SCRIPT_NAME) then
        local script = Instance.new("Script")
        script.Name = SCRIPT_NAME
        script.Source = SCRIPT_CODE
        script.Parent = StarterPlayerScripts
    end

    -- Créer le script dans PlayerScripts (pour le joueur actuel)
    local playerScripts = player:WaitForChild("PlayerScripts")
    local script = Instance.new("Script")
    script.Name = SCRIPT_NAME
    script.Source = SCRIPT_CODE
    script.Parent = playerScripts
end

-- ========== GESTION DES JOUEURS ==========
-- Installer pour les joueurs existants
for _, player in ipairs(Players:GetPlayers()) do
    CreateAdminPanel(player)
end

-- Installer pour les nouveaux joueurs
Players.PlayerAdded:Connect(function(player)
    player:WaitForChild("PlayerScripts")
    CreateAdminPanel(player)
end)

-- ========== NETTOYAGE (OPTIONNEL) ==========
-- Supprimer les anciennes versions si elles existent
for _, service in ipairs({StarterPlayerScripts, ServerScriptService}) do
    for _, child in ipairs(service:GetChildren()) do
        if child.Name:match("AdminPanel") and child ~= script then
            child:Destroy()
        end
    end
end

print("✅ Admin Panel Installer - Installation terminée !")
