local function MakeToggle(parent, layout, stateKey, label, sublabel, accent)
	accent = accent or C.blue
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 44)
	row.BackgroundColor3 = C.card
	row.BorderSizePixel = 0
	row.LayoutOrder = layout
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)

	local nameLbl = Instance.new("TextLabel")
	nameLbl.Size = UDim2.new(1, -70, 0, 20)
	nameLbl.Position = UDim2.new(0, 12, 0, 6)
	nameLbl.BackgroundTransparency = 1
	nameLbl.Font = Enum.Font.GothamBold
	nameLbl.Text = label
	nameLbl.TextColor3 = C.t1
	nameLbl.TextSize = 12
	nameLbl.TextXAlignment = Enum.TextXAlignment.Left
	nameLbl.ZIndex = 14
	nameLbl.Parent = row

	local subLbl = Instance.new("TextLabel")
	subLbl.Size = UDim2.new(1, -70, 0, 14)
	subLbl.Position = UDim2.new(0, 12, 0, 24)
	subLbl.BackgroundTransparency = 1
	subLbl.Font = Enum.Font.Gotham
	subLbl.Text = sublabel or ""
	subLbl.TextColor3 = C.t2
	subLbl.TextSize = 10
	subLbl.TextXAlignment = Enum.TextXAlignment.Left
	subLbl.ZIndex = 14
	subLbl.Parent = row

	-- Track (rail)
	local track = Instance.new("Frame")
	track.Size = UDim2.new(0, 38, 0, 20)
	track.Position = UDim2.new(1, -50, 0.5, -10)
	track.BackgroundColor3 = C.rOff
	track.BorderSizePixel = 0
	track.ZIndex = 14
	track.Parent = row
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

	-- Knob
	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 14, 0, 14)
	knob.Position = UDim2.new(0, 3, 0.5, -7)
	knob.BackgroundColor3 = C.kOff
	knob.BorderSizePixel = 0
	knob.ZIndex = 15
	knob.Parent = track
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local function Refresh()
		local on = State[stateKey]
		Tw(track, TI(0.18), {BackgroundColor3 = on and accent or C.rOff})
		Tw(knob,  TI(0.18), {
			BackgroundColor3 = on and C.kOn or C.kOff,
			Position = on and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
		})
		Tw(row, TI(0.18), {BackgroundColor3 = on and C.active or C.card})
	end

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
	btn.Text = ""; btn.ZIndex = 16; btn.Parent = row

	btn.MouseButton1Click:Connect(function()
		State[stateKey] = not State[stateKey]
		Refresh()
		UpdateBadge()
		if Dispatch[stateKey] then Dispatch[stateKey](State[stateKey]) end
	end)

	Refresh()
	return row
end

-- SECTION LABEL
local function MakeSection(parent, idx, text)
	local f = Instance.new("Frame")
	f.Size = UDim2.new(1, 0, 0, 22)
	f.BackgroundTransparency = 1
	f.LayoutOrder = idx
	f.Parent = parent

	local line1 = Instance.new("Frame")
	line1.Size = UDim2.new(0.3, 0, 0, 1)
	line1.Position = UDim2.new(0, 0, 0.5, 0)
	line1.BackgroundColor3 = C.sep
	line1.BorderSizePixel = 0
	line1.Parent = f

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(0.4, 0, 1, 0)
	lbl.Position = UDim2.new(0.3, 0, 0, 0)
	lbl.BackgroundTransparency = 1
	lbl.Font = Enum.Font.GothamBold
	lbl.Text = text
	lbl.TextColor3 = C.t2
	lbl.TextSize = 9
	lbl.Parent = f

	local line2 = Instance.new("Frame")
	line2.Size = UDim2.new(0.3, 0, 0, 1)
	line2.Position = UDim2.new(0.7, 0, 0.5, 0)
	line2.BackgroundColor3 = C.sep
	line2.BorderSizePixel = 0
	line2.Parent = f
	return f
end

