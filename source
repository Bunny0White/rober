--  SLIDER ROW (avec valeur réglable)
-- ════════════════════════════════════════════════════════════════
local function MakeSlider(label, unit, minVal, maxVal, defaultVal, cfgKey, order)
    local Row = Instance.new("Frame")
    Row.Size=UDim2.new(1,-12,0,52); Row.BackgroundColor3=C.bg2
    Row.BorderSizePixel=0; Row.LayoutOrder=order; Row.Parent=Scroll
    Instance.new("UICorner",Row).CornerRadius=UDim.new(0,10)

    local Lbl = Instance.new("TextLabel")
    Lbl.Size=UDim2.new(0.5,0,0,16); Lbl.Position=UDim2.new(0,12,0,8)
    Lbl.BackgroundTransparency=1; Lbl.Font=Enum.Font.GothamBold
    Lbl.Text=label; Lbl.TextColor3=C.txt2; Lbl.TextSize=10
    Lbl.LetterSpacing=1; Lbl.TextXAlignment=Enum.TextXAlignment.Left
    Lbl.ZIndex=13; Lbl.Parent=Row

    local ValBox = Instance.new("TextButton")
    ValBox.Size=UDim2.new(0,52,0,18); ValBox.Position=UDim2.new(1,-62,0,7)
    ValBox.BackgroundColor3=C.bg0; ValBox.BorderSizePixel=0
    ValBox.Font=Enum.Font.GothamBold
    ValBox.Text=tostring(defaultVal).." "..unit; ValBox.TextColor3=C.accent
    ValBox.TextSize=11; ValBox.AutoButtonColor=false; ValBox.ZIndex=14
    ValBox.Parent=Row
    Instance.new("UICorner",ValBox).CornerRadius=UDim.new(0,5)

    -- Track
    local TrackBg = Instance.new("Frame")
    TrackBg.Size=UDim2.new(1,-24,0,4); TrackBg.Position=UDim2.new(0,12,0,32)
    TrackBg.BackgroundColor3=C.railOff; TrackBg.BorderSizePixel=0; TrackBg.ZIndex=13
    TrackBg.Parent=Row
    Instance.new("UICorner",TrackBg).CornerRadius=UDim.new(1,0)

    local TrackFill = Instance.new("Frame")
    TrackFill.Size=UDim2.new((defaultVal-minVal)/(maxVal-minVal),0,1,0)
    TrackFill.BackgroundColor3=C.accent; TrackFill.BorderSizePixel=0; TrackFill.ZIndex=14
    TrackFill.Parent=TrackBg
    Instance.new("UICorner",TrackFill).CornerRadius=UDim.new(1,0)

    -- Knob slider
    local SK = Instance.new("Frame")
    local pct=(defaultVal-minVal)/(maxVal-minVal)
    SK.Size=UDim2.new(0,14,0,14); SK.AnchorPoint=Vector2.new(0.5,0.5)
    SK.Position=UDim2.new(pct,0,0.5,0); SK.BackgroundColor3=C.accent
    SK.BorderSizePixel=0; SK.ZIndex=15; SK.Parent=TrackBg
    Instance.new("UICorner",SK).CornerRadius=UDim.new(1,0)

    -- Drag du slider
    local sliderDragging=false
    local function SetSliderVal(v)
        v=math.clamp(math.floor(v+0.5), minVal, maxVal)
        CFG[cfgKey]=v
        local p=(v-minVal)/(maxVal-minVal)
        TrackFill.Size=UDim2.new(p,0,1,0)
        SK.Position=UDim2.new(p,0,0.5,0)
        ValBox.Text=tostring(v).." "..unit
        -- réappliquer si actif
        if cfgKey=="WalkSpeed" and State.Speed then ApplySpeed() end
        if cfgKey=="JumpPower" and State.JumpBoost then ApplyJump() end
        if cfgKey=="FlySpeed" and State.Fly then end  -- appliqué en continu via heartbeat
    end

    SK.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then sliderDragging=true end
    end)
    Track(UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then sliderDragging=false end
    end))
    Track(UserInputService.InputChanged:Connect(function(inp)
        if sliderDragging and inp.UserInputType==Enum.UserInputType.MouseMovement then
            local abs = TrackBg.AbsolutePosition
            local w   = TrackBg.AbsoluteSize.X
            local rel = (inp.Position.X - abs.X) / w
            SetSliderVal(minVal + rel*(maxVal-minVal))
        end
    end))
    TrackBg.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            local abs=TrackBg.AbsolutePosition; local w=TrackBg.AbsoluteSize.X
            local rel=(inp.Position.X-abs.X)/w
            SetSliderVal(minVal+rel*(maxVal-minVal))
        end
    end)

    Row.BackgroundTransparency=1
    task.delay(0.1+order*0.055, function()
        if Row and Row.Parent then
            Tween(Row,TI(0.3,Enum.EasingStyle.Quad),{BackgroundTransparency=0})
        end
    end)
end

