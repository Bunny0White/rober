-- ============================================================
--  FACTORY — créer un bouton toggle
-- ============================================================
local COLOR_OFF = Color3.fromRGB(30, 26, 44)
local COLOR_ON  = Color3.fromRGB(60, 30, 100)
local ACCENT    = Color3.fromRGB(160, 100, 255)
local ACCENT_ON = Color3.fromRGB(200, 150, 255)

local function createToggleButton(labelText, icon, order)
    local btn = Instance.new("TextButton")
    btn.Name              = labelText
    btn.Size              = UDim2.new(1, 0, 0, 46)
    btn.BackgroundColor3  = COLOR_OFF
    btn.BorderSizePixel   = 0
    btn.Text              = ""
    btn.LayoutOrder       = order
    btn.AutoButtonColor   = false
    btn.Parent            = scrollFrame

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color     = Color3.fromRGB(60, 45, 90)
    stroke.Thickness = 1

    -- Icône
    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size              = UDim2.new(0, 30, 1, 0)
    iconLbl.Position          = UDim2.new(0, 10, 0, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text              = icon
    iconLbl.TextSize          = 18
    iconLbl.Font              = Enum.Font.GothamBold
    iconLbl.TextColor3        = ACCENT
    iconLbl.ZIndex            = 2
    iconLbl.Parent            = btn

    -- Label
    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size              = UDim2.new(1, -80, 1, 0)
    nameLbl.Position          = UDim2.new(0, 46, 0, 0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text              = labelText
    nameLbl.Font              = Enum.Font.Gotham
    nameLbl.TextSize          = 14
    nameLbl.TextColor3        = Color3.fromRGB(200, 190, 220)
    nameLbl.TextXAlignment    = Enum.TextXAlignment.Left
    nameLbl.ZIndex            = 2
    nameLbl.Parent            = btn

    -- Pastille ON/OFF
    local badge = Instance.new("TextLabel")
    badge.Size              = UDim2.new(0, 44, 0, 22)
    badge.Position          = UDim2.new(1, -52, 0.5, -11)
    badge.BackgroundColor3  = Color3.fromRGB(50, 40, 70)
    badge.Text              = "OFF"
    badge.Font              = Enum.Font.GothamBold
    badge.TextSize          = 11
    badge.TextColor3        = Color3.fromRGB(150, 130, 180)
    badge.ZIndex            = 2
    badge.Parent            = btn
    Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 6)

    -- Hover
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(40, 34, 58)
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = states[labelText] and COLOR_ON or COLOR_OFF
        }):Play()
    end)

    -- Méthode pour mettre à jour l'état visuel
    local function setVisual(on)
        TweenService:Create(btn, TweenInfo.new(0.2), {
            BackgroundColor3 = on and COLOR_ON or COLOR_OFF
        }):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {
            Color = on and ACCENT or Color3.fromRGB(60, 45, 90)
        }):Play()
        badge.Text              = on and "ON" or "OFF"
        badge.TextColor3        = on and ACCENT_ON or Color3.fromRGB(150, 130, 180)
        badge.BackgroundColor3  = on and Color3.fromRGB(60, 30, 100) or Color3.fromRGB(50, 40, 70)
        iconLbl.TextColor3      = on and ACCENT_ON or ACCENT
    end

    return btn, setVisual
end

