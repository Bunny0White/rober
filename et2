local function setButtonsState(isRunning)
	startBtn.Active             = not isRunning
	startBtn.BackgroundTransparency = isRunning and 0.5 or 0
	pauseBtn.Active             = isRunning
	pauseBtn.BackgroundTransparency = isRunning and 0 or 0.5
	stopBtn.Active              = isRunning
	stopBtn.BackgroundTransparency  = isRunning and 0 or 0.5
end

local function updateProgress()
	local pct = State.total > 0 and (State.current / State.total) or 0
	TweenService:Create(progressFill, TweenInfo.new(0.3), {
		Size = UDim2.new(pct, 0, 1, 0)
	}):Play()

	local statusTxt
	if State.paused then
		statusTxt = "En pause"
	elseif State.running then
		statusTxt = "En cours..."
	elseif State.current > 0 and State.current == State.total then
		statusTxt = "✔ Terminé !"
	else
		statusTxt = "En attente"
	end

	progressLbl.Text = State.current .. " / " .. State.total .. "  —  " .. statusTxt
end

local function resetState()
	State.running = false
	State.paused  = false
	State.stopped = false
	State.current = 0
	State.total   = 0
	setButtonsState(false)
	updateProgress()
end

