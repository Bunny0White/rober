	TitleText.Parent         = TitleBar

	-- Bouton Fermer modal
	local CloseBtn = Instance.new("TextButton")
	CloseBtn.Size            = UDim2.new(0, 28, 0, 28)
	CloseBtn.Position        = UDim2.new(1, -34, 0, 6)
	CloseBtn.BackgroundColor3 = C.danger
	CloseBtn.Text            = "✕"
	CloseBtn.TextSize        = 13
	CloseBtn.Font            = Enum.Font.GothamBold
	CloseBtn.TextColor3      = Color3.new(1,1,1)
	CloseBtn.ZIndex          = 22
	CloseBtn.Parent          = TitleBar
	Instance.new("UICorner", CloseBtn).CornerRadius = UDim.new(1, 0)

	CloseBtn.MouseButton1Click:Connect(function()
		Modal:Destroy()
		activeModal = nil
	end)

	makeDraggable(Modal, TitleBar)

	-- Zone de texte (ScrollingFrame)
	local TextScroll = Instance.new("ScrollingFrame")
	TextScroll.Name              = "TextScroll"
	TextScroll.Size              = UDim2.new(1, -16, 1, -96)
	TextScroll.Position          = UDim2.new(0, 8, 0, 48)
	TextScroll.BackgroundColor3  = C.surface
	TextScroll.BorderSizePixel   = 0
	TextScroll.ScrollBarThickness = 5
	TextScroll.ScrollBarImageColor3 = C.accent
	TextScroll.ZIndex            = 21
	TextScroll.Parent            = Modal
	Instance.new("UICorner", TextScroll).CornerRadius = UDim.new(0, 8)

	local ReportLabel = Instance.new("TextLabel")
	ReportLabel.Name             = "ReportLabel"
	ReportLabel.Size             = UDim2.new(1, -12, 0, 0)   -- hauteur auto
	ReportLabel.Position         = UDim2.new(0, 6, 0, 6)
	ReportLabel.BackgroundTransparency = 1
	ReportLabel.Text             = report
	ReportLabel.TextColor3       = C.text
	ReportLabel.TextSize         = 11
	ReportLabel.Font             = Enum.Font.Code
	ReportLabel.TextXAlignment   = Enum.TextXAlignment.Left
	ReportLabel.TextYAlignment   = Enum.TextYAlignment.Top
	ReportLabel.TextWrapped      = true
	ReportLabel.RichText         = false
	ReportLabel.AutomaticSize    = Enum.AutomaticSize.Y
	ReportLabel.ZIndex           = 22
	ReportLabel.Parent           = TextScroll

	-- Sync canvas height
	ReportLabel:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
		TextScroll.CanvasSize = UDim2.new(0, 0, 0, ReportLabel.AbsoluteSize.Y + 12)
	end)

	-- Affichage dans la console aussi
	print(report)

	-- Bouton Copier
	local CopyBtn = Instance.new("TextButton")
	CopyBtn.Name             = "CopyBtn"
	CopyBtn.Size             = UDim2.new(1, -16, 0, 36)
	CopyBtn.Position         = UDim2.new(0, 8, 1, -44)
	CopyBtn.BackgroundColor3 = C.accent
	CopyBtn.Text             = "📋  Copier le rapport"
	CopyBtn.TextSize         = 13
	CopyBtn.Font             = Enum.Font.GothamBold
	CopyBtn.TextColor3       = Color3.new(1,1,1)
	CopyBtn.ZIndex           = 22
	CopyBtn.Parent           = Modal
	Instance.new("UICorner", CopyBtn).CornerRadius = UDim.new(0, 8)

	CopyBtn.MouseEnter:Connect(function()
		CopyBtn.BackgroundColor3 = C.accentHov
