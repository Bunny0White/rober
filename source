local PageHolder = Instance.new("Frame")
PageHolder.Size=UDim2.new(1,0,1,-54); PageHolder.Position=UDim2.new(0,0,0,54)
PageHolder.BackgroundTransparency=1; PageHolder.BorderSizePixel=0
PageHolder.ClipsDescendants=true; PageHolder.ZIndex=11; PageHolder.Parent=Content

local function SwitchTab(key)
    if CurrentTab==key then return end
    CurrentTab=key
    for _,t in ipairs(Tabs) do
        local isActive=(t.key==key)
        if isActive then
            Tween(t.btn,TI(0.18),{BackgroundColor3=C.bg4})
            Tween(t.btnIcon,TI(0.18),{TextColor3=C.accent})
            t.page.Visible=true
            Tween(t.page,TI(0.22,Enum.EasingStyle.Quad),{BackgroundTransparency=0})
            HeaderTitle.Text=t.title
        else
            Tween(t.btn,TI(0.18),{BackgroundColor3=Color3.fromRGB(0,0,0)})
            t.btn.BackgroundTransparency=1
            Tween(t.btnIcon,TI(0.18),{TextColor3=C.txt2})
            t.page.Visible=false
        end
    end
end

local function AddTab(key, icon, title)
    local btn=Instance.new("Frame")
    btn.Size=UDim2.new(1,0,0,38); btn.BackgroundTransparency=1
    btn.BackgroundColor3=Color3.fromRGB(0,0,0); btn.BorderSizePixel=0
    btn.LayoutOrder=#Tabs+1; btn.ZIndex=14; btn.Parent=Sidebar
    Instance.new("UICorner",btn).CornerRadius=UDim.new(0,8)

    local btnIcon=Instance.new("TextLabel")
    btnIcon.Size=UDim2.new(1,0,0.55,0); btnIcon.Position=UDim2.new(0,0,0,3)
    btnIcon.BackgroundTransparency=1; btnIcon.Font=Enum.Font.GothamBold
    btnIcon.Text=icon; btnIcon.TextSize=16; btnIcon.TextColor3=C.txt2
    btnIcon.ZIndex=15; btnIcon.Parent=btn

    local btnLbl=Instance.new("TextLabel")
    btnLbl.Size=UDim2.new(1,0,0.4,0); btnLbl.Position=UDim2.new(0,0,0.58,0)
    btnLbl.BackgroundTransparency=1; btnLbl.Font=Enum.Font.GothamBold
    btnLbl.Text=title:sub(1,4):upper(); btnLbl.TextSize=7; btnLbl.TextColor3=C.txt2
    btnLbl.LetterSpacing=0.5; btnLbl.ZIndex=15; btnLbl.Parent=btn

    local clickBtn=Instance.new("TextButton")
    clickBtn.Size=UDim2.new(1,0,1,0); clickBtn.BackgroundTransparency=1
    clickBtn.Text=""; clickBtn.ZIndex=20; clickBtn.Parent=btn

    local page=Instance.new("ScrollingFrame")
    page.Size=UDim2.new(1,0,1,0); page.BackgroundTransparency=1
    page.BorderSizePixel=0; page.ScrollBarThickness=3
    page.ScrollBarImageColor3=C.accent; page.CanvasSize=UDim2.new(0,0,0,0)
    page.Visible=false; page.ZIndex=11; page.Parent=PageHolder

    local pl=Instance.new("UIListLayout",page)
    pl.Padding=UDim.new(0,0); pl.SortOrder=Enum.SortOrder.LayoutOrder
    pl.HorizontalAlignment=Enum.HorizontalAlignment.Center
    local pp=Instance.new("UIPadding",page)
    pp.PaddingTop=UDim.new(0,8); pp.PaddingBottom=UDim.new(0,10)
    pp.PaddingLeft=UDim.new(0,10); pp.PaddingRight=UDim.new(0,10)

    pl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize=UDim2.new(0,0,0,pl.AbsoluteContentSize.Y+18)
    end)

    local entry={key=key,btn=btn,btnIcon=btnIcon,page=page,title=title}
    table.insert(Tabs,entry)

    clickBtn.MouseButton1Click:Connect(function() SwitchTab(key) end)
    clickBtn.MouseEnter:Connect(function()
        if CurrentTab~=key then Tween(btn,TI(0.12),{BackgroundTransparency=0.7}) end
    end)
    clickBtn.MouseLeave:Connect(function()
        if CurrentTab~=key then Tween(btn,TI(0.12),{BackgroundTransparency=1}) end
    end)

    return page
end

