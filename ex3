--[[
    UI Debugger – Version Stable
    - Toggle draggable
    - Menu draggable listant les ScreenGui
    - Modal draggable + fermable avec ScrollingFrame
    - Dump sécurisé (limite profondeur + taille)
    - Copie via TextBox natif (sans setclipboard)
]]

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

---------------------------------------------------------------------
-- DRAGGABLE
---------------------------------------------------------------------
local function makeDraggable(frame, dragHandle)
    dragHandle = dragHandle or frame
    local dragging = false
    local dragStart, startPos

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    dragHandle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

---------------------------------------------------------------------
-- COPIE NATIVE (sans setclipboard)
---------------------------------------------------------------------
local function copyToClipboard(text)
    local tempGui = Instance.new("ScreenGui")
    tempGui.Name = "CopyHelper"
    tempGui.ResetOnSpawn = false
    tempGui.DisplayOrder = 99999
    tempGui.Parent = playerGui

    local tb = Instance.new("TextBox")
    tb.Size = UDim2.fromOffset(1, 1)
    tb.Position = UDim2.fromOffset(-9999, -9999)
    tb.BackgroundTransparency = 1
    tb.TextTransparency = 1
    tb.Text = text
    tb.Parent = tempGui

    tb:CaptureFocus()
    tb.SelectionStart = 1
    tb.CursorPosition = #text + 1

    task.delay(0.2, function()
        tb:ReleaseFocus()
        tempGui:Destroy()
    end)
end

---------------------------------------------------------------------
-- DUMP SÉCURISÉ
---------------------------------------------------------------------
local function dumpGui(gui)
    local MAX_DEPTH = 5
    local MAX_LEN = 20000
    local currentLen = 0

    local function safeAppend(str, add)
        if currentLen > MAX_LEN then return str end
        str = str .. add
        currentLen += #add
        return str
    end

    local function dump(obj, indent, depth)
        indent = indent or 0
        depth = depth or 0
        local prefix = string.rep("  ", indent)
        local str = ""

        if depth > MAX_DEPTH then
            return safeAppend(str, prefix .. "... (profondeur max atteinte)\n")
        end

        str = safeAppend(str, prefix .. "[" .. obj.ClassName .. "] " .. obj.Name .. "\n")

        local props = {
            "Visible", "Active", "Size", "Position", "AnchorPoint",
            "BackgroundColor3", "BackgroundTransparency", "ZIndex",
            "Text", "TextColor3", "TextSize", "Font",
            "Image", "ImageColor3", "Rotation", "ClipsDescendants"
        }

        for _, prop in ipairs(props) do
            pcall(function()
                local v = obj[prop]
                if typeof(v) == "Color3" then
                    v = string.format("RGB(%d, %d, %d)",
                        math.round(v.R * 255),
                        math.round(v.G * 255),
                        math.round(v.B * 255))
                elseif typeof(v) == "UDim2" then
                    v = string.format("UDim2(%.2f, %d, %.2f, %d)",
                        v.X.Scale, v.X.Offset, v.Y.Scale, v.Y.Offset)
                elseif typeof(v) == "Vector2" then
                    v = string.format("Vector2(%.2f, %.2f)", v.X, v.Y)
                elseif typeof(v) == "UDim" then
                    v = string.format("UDim(%.2f, %d)", v.Scale, v.Offset)
                else
                    v = tostring(v)
                end
                str = safeAppend(str, prefix .. "  ." .. prop .. " = " .. v .. "\n")
            end)
        end

        -- Parent info (seulement au 1er niveau)
        if depth == 0 and obj.Parent then
            str = safeAppend(str, prefix .. "  .Parent = [" .. obj.Parent.ClassName .. "] " .. obj.Parent.Name .. "\n")
        end

        str = safeAppend(str, "\n")

        for _, child in ipairs(obj:GetChildren()) do
            if currentLen > MAX_LEN then
                str = safeAppend(str, prefix .. "... (taille max atteinte)\n")
                break
            end
            str = str .. dump(child, indent + 1, depth + 1)
        end

        return str
    end

    return dump(gui)
end

