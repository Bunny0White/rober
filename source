	if FreeCamConn then FreeCamConn:Disconnect(); FreeCamConn = nil end
	local cam = workspace.CurrentCamera
	if on then
		FreeCamPart = Instance.new("Part")
		FreeCamPart.Anchored = true; FreeCamPart.CanCollide = false
		FreeCamPart.Transparency = 1; FreeCamPart.Size = Vector3.one
		FreeCamPart.CFrame = cam.CFrame; FreeCamPart.Parent = workspace
		cam.CameraType = Enum.CameraType.Scriptable
		FreeCamConn = RunService.RenderStepped:Connect(function(dt)
			if not State.FreeCam then return end
			local d = Vector3.zero; local UIS = UserInputService
			if UIS:IsKeyDown(Enum.KeyCode.W) or UIS:IsKeyDown(Enum.KeyCode.Z) then d = d + cam.CFrame.LookVector  end
			if UIS:IsKeyDown(Enum.KeyCode.S)                                   then d = d - cam.CFrame.LookVector  end
			if UIS:IsKeyDown(Enum.KeyCode.A) or UIS:IsKeyDown(Enum.KeyCode.Q) then d = d - cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.D)                                   then d = d + cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.E)     then d = d + Vector3.yAxis end
			if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then d = d - Vector3.yAxis end
			local spd = UIS:IsKeyDown(Enum.KeyCode.LeftShift) and 2 or 0.5
			cam.CFrame = cam.CFrame * CFrame.new(d * spd)
		end)
		Notify("FreeCam", "ZQSD · E · Ctrl", "on")
	else
		if FreeCamPart then FreeCamPart:Destroy(); FreeCamPart = nil end
		cam.CameraType = Enum.CameraType.Custom
		Notify("FreeCam", "Caméra normale", "off")
	end
end

