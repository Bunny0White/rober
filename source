-- FLY ─────────────────────────────────────────────────────────────────
local function StartFly()
	local r = Root(); local h = Hum(); if not r or not h then return end
	h.PlatformStand = true
	FlyBV = Instance.new("BodyVelocity"); FlyBV.MaxForce = Vector3.new(1e5,1e5,1e5); FlyBV.Parent = r
	FlyBG = Instance.new("BodyGyro"); FlyBG.MaxTorque = Vector3.new(1e5,1e5,1e5)
	FlyBG.CFrame = r.CFrame; FlyBG.P = 1e4; FlyBG.Parent = r
	local cam = workspace.CurrentCamera
	FlyConn = RunService.Heartbeat:Connect(function()
		if not State.Fly or not FlyBV then return end
		local d = Vector3.zero; local UIS = UserInputService
		if UIS:IsKeyDown(Enum.KeyCode.W) or UIS:IsKeyDown(Enum.KeyCode.Z) then d = d + cam.CFrame.LookVector  end
		if UIS:IsKeyDown(Enum.KeyCode.S)                                   then d = d - cam.CFrame.LookVector  end
		if UIS:IsKeyDown(Enum.KeyCode.A) or UIS:IsKeyDown(Enum.KeyCode.Q) then d = d - cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D)                                   then d = d + cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.Space)     then d = d + Vector3.yAxis end
		if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then d = d - Vector3.yAxis end
		FlyBV.Velocity = (d.Magnitude > 0 and d.Unit or Vector3.zero) * CFG.FlySpeed
		FlyBG.CFrame   = cam.CFrame
	end)
end
local function StopFly()
	if FlyConn then FlyConn:Disconnect(); FlyConn = nil end
	if FlyBV   then FlyBV:Destroy();   FlyBV = nil end
	if FlyBG   then FlyBG:Destroy();   FlyBG = nil end
	local h = Hum(); if h then h.PlatformStand = false end
end
local function ToggleFly(on)
	if on then StartFly(); Notify("Fly Mode", "ZQSD · Espace · Shift", "on")
	else StopFly(); Notify("Fly Mode", "Désactivé", "off") end
end

