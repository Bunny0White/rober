--------------------------------------------------
-- Démarrer
--------------------------------------------------
startBtn.MouseButton1Click:Connect(function()
	if State.running then return end

	local total = math.floor(tonumber(inputBox.Text) or 0)
	if total <= 0 then
		addLog("[Erreur] Entrez un nombre valide.", Color3.fromRGB(220, 80, 80))
		return
	end

	State.running = true
	State.paused  = false
	State.stopped = false
	State.total   = total
	State.current = 0
	setButtonsState(true)
	pauseBtn.Text = "⏸  Pause"

	addLog("[Start] Démarrage : " .. total .. " mort(s)", Color3.fromRGB(100, 200, 120))
	addLog("[Config] Délai : " .. State.minDelay .. "s – " .. State.maxDelay .. "s", Color3.fromRGB(140, 140, 200))

	task.spawn(function()
		for i = 1, total do

			-- Attente si en pause
			while State.paused do
				task.wait(0.2)
			end

			if State.stopped then
				break
			end

			State.current = i
			updateProgress()

			local character = player.Character or player.CharacterAdded:Wait()
			local humanoid  = character:FindFirstChildOfClass("Humanoid")

			if humanoid and humanoid.Health > 0 then
				humanoid.Health = 0
				addLog("[" .. i .. "/" .. total .. "] Mort infligée ✓", Color3.fromRGB(200, 100, 100))
			else
				addLog("[" .. i .. "/" .. total .. "] Humanoid introuvable", Color3.fromRGB(220, 150, 50))
			end

			player.CharacterAdded:Wait()

			-- Attente si en pause avant le délai
			while State.paused do
				task.wait(0.2)
			end
			if State.stopped then break end

			local delay = State.minDelay + math.random() * (State.maxDelay - State.minDelay)
			task.wait(delay)
		end

		local wasAborted = State.stopped
		State.running = false
		State.paused  = false
		State.stopped = false

		setButtonsState(false)
		pauseBtn.Text = "⏸  Pause"
		updateProgress()

		if wasAborted then
			addLog("[Stop] Séquence interrompue.", Color3.fromRGB(220, 100, 60))
		else
			addLog("[Fin] Séquence complète ! " .. total .. "/" .. total, Color3.fromRGB(100, 220, 100))
			State.current = State.total
			updateProgress()
		end
	end)
end)

