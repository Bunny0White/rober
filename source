-- ── 1. ESP ──────────────────────────────────────────────────────────────
local function ApplyESP(player)
    if player==LocalPlayer then return end
    local c=player.Character; if not c then return end
    if c:FindFirstChild("__APesp") then return end
    local hl=Instance.new("Highlight")
    hl.Name="__APesp"; hl.FillColor=CFG.ESPColor; hl.OutlineColor=CFG.ESPOutline
    hl.FillTransparency=0.55; hl.OutlineTransparency=0
    hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=c
end
local function RemoveESP(player)
    local c=player.Character; if not c then return end
    local hl=c:FindFirstChild("__APesp"); if hl then hl:Destroy() end
end
local function ToggleESP(on)
    if on then
        for _,p in ipairs(Players:GetPlayers()) do ApplyESP(p) end
        Track(Players.PlayerAdded:Connect(function(p)
            Track(p.CharacterAdded:Connect(function()
                task.wait(0.5); if State.ESP then ApplyESP(p) end
            end))
        end))
        Notify("ESP","Joueurs visibles à travers les murs","on")
    else
        for _,p in ipairs(Players:GetPlayers()) do RemoveESP(p) end
        Notify("ESP","Désactivé","off")
    end
end

-- ── 2. SPEED ────────────────────────────────────────────────────────────
local function ApplySpeed() local h=Hum(); if h then h.WalkSpeed=CFG.WalkSpeed end end
local function ToggleSpeed(on)
    if on then ApplySpeed(); Notify("Speed Boost","WalkSpeed → "..CFG.WalkSpeed.." u/s","on")
    else local h=Hum(); if h then h.WalkSpeed=16 end; Notify("Speed Boost","WalkSpeed → 16 u/s (défaut)","off") end
